
;; Memory layouts are C compatible structs.

layout Matrix3x3
  [m11 :: Float] [m12 :: Float] [m13 :: Float]
  [m21 :: Float] [m22 :: Float] [m23 :: Float]
  [m31 :: Float] [m32 :: Float] [m33 :: Float]

;; Layouts can have methods

layout Vec3
  [x :: Float]
  [y :: Float]
  [z :: Float]
  where
    method ->array :: Self -> Array
      s -> [s.x s.y s.z]

define v Vec3 1.0 2.0 3.0

show v->array





