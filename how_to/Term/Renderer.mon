define text-vert-spv-len 1324



define MAX-VERTICES 65536
define MAX-TEXTURES 32

;;; Structs

(layout Texture2D
  [image   :: VkImage]
  [memory  :: VkDeviceMemory]
  [view    :: VkImageView]
  [sampler :: VkSampler]
  [descSet :: VkDescriptorSet]
  [width   :: U32]
  [height  :: U32]
  [loaded  :: Bool])

(layout Character
  [ax :: F32]  ; advance.x
  [ay :: F32]  ; advance.y
  [bw :: F32]  ; bitmap.width
  [bh :: F32]  ; bitmap.rows
  [bl :: F32]  ; bitmap_left
  [bt :: F32]  ; bitmap_top
  [tx :: F32]  ; x offset in texture atlas (0.0 to 1.0)
  [ty :: F32])

(layout Font
  [texture :: Texture2D]
  [width   :: I32]
  [height  :: I32]
  [ascent  :: I32]
  [descent :: I32]
  [chars   :: [Character 128]])

(layout Color
  [r :: F32]
  [g :: F32]
  [b :: F32]
  [a :: F32])

(layout Vertex
  [x :: F32]
  [y :: F32]
  [u :: F32]
  [v :: F32]
  [r :: F32]
  [g :: F32]
  [b :: F32]
  [a :: F32])

(layout TextureBatch
  [texture -> Texture2D]
  [start-vertex :: I32]
  [vertex-count :: I32])

;;; Globals
;; allocated at import time, no init function needed

;; CPU-side geometry buffers
define [g-vertices -> Vertex]      (calloc MAX-VERTICES 32)
define [g-batches -> TextureBatch] (calloc MAX-TEXTURES 24)
define [g-vertex-count :: I32] 0
define [g-batch-count  :: I32] 0

;; Screen dimensions — set from Term.mon after window creation
define [g-screen-w :: F32] 640.0
define [g-screen-h :: F32] 480.0

;; Vulkan handles — set from Term.mon after Vulkan init
define g-device          0
define g-phys-device     0
define g-queue           0
define g-pipeline        0
define g-pipeline-layout 0
define g-desc-set-layout 0
define g-vert-buffer     0
define g-vert-memory     0

;;; Colors

define WHITE  (Color 1.0 1.0 1.0 1.0)
define BLACK  (Color 0.0 0.0 0.0 1.0)
define RED    (Color 1.0 0.0 0.0 1.0)
define GREEN  (Color 0.0 1.0 0.0 1.0)
define BLUE   (Color 0.0 0.0 1.0 1.0)

;;; Internal: memory type helper

(define (find-memory-type [type-filter :: U32]
                          [properties  :: U32] -> U32)
  (define props (VkPhysicalDeviceMemoryProperties))
  (vkGetPhysicalDeviceMemoryProperties g-phys-device &props)
  (define [result :: U32] 0)
  (for [i 0 props.memoryTypeCount]
    (define mt (props.memoryTypes i))
    (if (((type-filter >> i) & 1) &
         ((mt.propertyFlags & properties) = properties))
      (begin
        (set! result i)
        (set! i props.memoryTypeCount))))
  result)

;;; Internal: shader module

(define (create-shader-module [code       -> U8]
                              [code-size :: I32] -> VkShaderModule)
  (define info (VkShaderModuleCreateInfo))
  (set! info.sType    VK_STRUCTURE_TYPE_SHADER_MODULE_CREATE_INFO)
  (set! info.codeSize code-size)
  (set! info.pCode    code)
  (define sm (VkShaderModule))
  (vkCreateShaderModule g-device &info 0 &sm)
  sm)

;;; Internal: descriptor set layout

(define (create-desc-set-layout -> VkDescriptorSetLayout)
  (define binding (VkDescriptorSetLayoutBinding))
  (set! binding.binding         0)
  (set! binding.descriptorType  VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER)
  (set! binding.descriptorCount 1)
  (set! binding.stageFlags      VK_SHADER_STAGE_FRAGMENT_BIT)
  (define info (VkDescriptorSetLayoutCreateInfo))
  (set! info.sType        VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO)
  (set! info.bindingCount 1)
  (set! info.pBindings    &binding)
  (define dsl (VkDescriptorSetLayout))
  (vkCreateDescriptorSetLayout g-device &info 0 &dsl)
  dsl)

;;; Pipeline creation
;;  called once from Term.mon after Vulkan is up

(define (renderer-create-pipeline [render-pass :: VkRenderPass])
  (set! g-desc-set-layout (create-desc-set-layout))

  ;; Shader modules
  (define vert-mod (create-shader-module text-vert-spv text-vert-spv-len))
  (define frag-mod (create-shader-module text-frag-spv text-frag-spv-len))

  ;; Shader stages
  (define stages (calloc 2 64))
  (define vert-stage (VkPipelineShaderStageCreateInfo))
  (set! vert-stage.sType  VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO)
  (set! vert-stage.stage  VK_SHADER_STAGE_VERTEX_BIT)
  (set! vert-stage.module vert-mod)
  (set! vert-stage.pName  "main")
  (define frag-stage (VkPipelineShaderStageCreateInfo))
  (set! frag-stage.sType  VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO)
  (set! frag-stage.stage  VK_SHADER_STAGE_FRAGMENT_BIT)
  (set! frag-stage.module frag-mod)
  (set! frag-stage.pName  "main")
  (memcpy stages        &vert-stage 64)
  (memcpy (stages + 64) &frag-stage 64)

  ;; Vertex binding — stride 32 = sizeof(Vertex)
  (define vert-binding (VkVertexInputBindingDescription))
  (set! vert-binding.binding   0)
  (set! vert-binding.stride    32)
  (set! vert-binding.inputRate VK_VERTEX_INPUT_RATE_VERTEX)

  ;; Vertex attributes — pos(vec2) uv(vec2) color(vec4)
  (define attrs (calloc 3 16))
  (define attr-pos   (VkVertexInputAttributeDescription))
  (define attr-uv    (VkVertexInputAttributeDescription))
  (define attr-color (VkVertexInputAttributeDescription))
  (set! attr-pos.binding   0) (set! attr-pos.location   0)
  (set! attr-pos.format    VK_FORMAT_R32G32_SFLOAT)
  (set! attr-pos.offset    0)
  (set! attr-uv.binding    0) (set! attr-uv.location    1)
  (set! attr-uv.format     VK_FORMAT_R32G32_SFLOAT)
  (set! attr-uv.offset     8)
  (set! attr-color.binding 0) (set! attr-color.location 2)
  (set! attr-color.format  VK_FORMAT_R32G32B32A32_SFLOAT)
  (set! attr-color.offset  16)
  (memcpy attrs        &attr-pos   16)
  (memcpy (attrs + 16) &attr-uv    16)
  (memcpy (attrs + 32) &attr-color 16)

  (define vert-input (VkPipelineVertexInputStateCreateInfo))
  (set! vert-input.sType                           VK_STRUCTURE_TYPE_PIPELINE_VERTEX_INPUT_STATE_CREATE_INFO)
  (set! vert-input.vertexBindingDescriptionCount   1)
  (set! vert-input.pVertexBindingDescriptions      &vert-binding)
  (set! vert-input.vertexAttributeDescriptionCount 3)
  (set! vert-input.pVertexAttributeDescriptions    attrs)

  (define ia (VkPipelineInputAssemblyStateCreateInfo))
  (set! ia.sType                  VK_STRUCTURE_TYPE_PIPELINE_INPUT_ASSEMBLY_STATE_CREATE_INFO)
  (set! ia.topology               VK_PRIMITIVE_TOPOLOGY_TRIANGLE_LIST)
  (set! ia.primitiveRestartEnable 0)

  (define raster (VkPipelineRasterizationStateCreateInfo))
  (set! raster.sType       VK_STRUCTURE_TYPE_PIPELINE_RASTERIZATION_STATE_CREATE_INFO)
  (set! raster.polygonMode VK_POLYGON_MODE_FILL)
  (set! raster.cullMode    VK_CULL_MODE_NONE)
  (set! raster.frontFace   VK_FRONT_FACE_CLOCKWISE)
  (set! raster.lineWidth   1.0)

  (define ms (VkPipelineMultisampleStateCreateInfo))
  (set! ms.sType                VK_STRUCTURE_TYPE_PIPELINE_MULTISAMPLE_STATE_CREATE_INFO)
  (set! ms.rasterizationSamples VK_SAMPLE_COUNT_1_BIT)

  ;; Alpha blending
  (define blend-att (VkPipelineColorBlendAttachmentState))
  (set! blend-att.blendEnable         1)
  (set! blend-att.srcColorBlendFactor VK_BLEND_FACTOR_SRC_ALPHA)
  (set! blend-att.dstColorBlendFactor VK_BLEND_FACTOR_ONE_MINUS_SRC_ALPHA)
  (set! blend-att.colorBlendOp        VK_BLEND_OP_ADD)
  (set! blend-att.srcAlphaBlendFactor VK_BLEND_FACTOR_ONE)
  (set! blend-att.dstAlphaBlendFactor VK_BLEND_FACTOR_ZERO)
  (set! blend-att.alphaBlendOp        VK_BLEND_OP_ADD)
  (set! blend-att.colorWriteMask      (VK_COLOR_COMPONENT_R_BIT ∨
                                       VK_COLOR_COMPONENT_G_BIT ∨
                                       VK_COLOR_COMPONENT_B_BIT ∨
                                       VK_COLOR_COMPONENT_A_BIT))

  (define blend (VkPipelineColorBlendStateCreateInfo))
  (set! blend.sType           VK_STRUCTURE_TYPE_PIPELINE_COLOR_BLEND_STATE_CREATE_INFO)
  (set! blend.attachmentCount 1)
  (set! blend.pAttachments    &blend-att)

  ;; Dynamic viewport + scissor
  (define dyn-states (calloc 2 4))
  (set! (dyn-states 0) VK_DYNAMIC_STATE_VIEWPORT)
  (set! (dyn-states 1) VK_DYNAMIC_STATE_SCISSOR)
  (define dyn (VkPipelineDynamicStateCreateInfo))
  (set! dyn.sType             VK_STRUCTURE_TYPE_PIPELINE_DYNAMIC_STATE_CREATE_INFO)
  (set! dyn.dynamicStateCount 2)
  (set! dyn.pDynamicStates    dyn-states)

  (define vp-state (VkPipelineViewportStateCreateInfo))
  (set! vp-state.sType         VK_STRUCTURE_TYPE_PIPELINE_VIEWPORT_STATE_CREATE_INFO)
  (set! vp-state.viewportCount 1)
  (set! vp-state.scissorCount  1)

  ;; Push constants: vec2 screenSize
  (define push-range (VkPushConstantRange))
  (set! push-range.stageFlags VK_SHADER_STAGE_VERTEX_BIT)
  (set! push-range.offset     0)
  (set! push-range.size       8)

  (define layout-info (VkPipelineLayoutCreateInfo))
  (set! layout-info.sType                  VK_STRUCTURE_TYPE_PIPELINE_LAYOUT_CREATE_INFO)
  (set! layout-info.setLayoutCount         1)
  (set! layout-info.pSetLayouts            &g-desc-set-layout)
  (set! layout-info.pushConstantRangeCount 1)
  (set! layout-info.pPushConstantRanges    &push-range)
  (define pipeline-layout (VkPipelineLayout))
  (vkCreatePipelineLayout g-device &layout-info 0 &pipeline-layout)
  (set! g-pipeline-layout pipeline-layout)

  (define pipe-info (VkGraphicsPipelineCreateInfo))
  (set! pipe-info.sType               VK_STRUCTURE_TYPE_GRAPHICS_PIPELINE_CREATE_INFO)
  (set! pipe-info.stageCount          2)
  (set! pipe-info.pStages             stages)
  (set! pipe-info.pVertexInputState   &vert-input)
  (set! pipe-info.pInputAssemblyState &ia)
  (set! pipe-info.pViewportState      &vp-state)
  (set! pipe-info.pRasterizationState &raster)
  (set! pipe-info.pMultisampleState   &ms)
  (set! pipe-info.pColorBlendState    &blend)
  (set! pipe-info.pDynamicState       &dyn)
  (set! pipe-info.layout              pipeline-layout)
  (set! pipe-info.renderPass          render-pass)
  (set! pipe-info.subpass             0)

  (define pipeline (VkPipeline))
  (vkCreateGraphicsPipelines g-device 0 1 &pipe-info 0 &pipeline)
  (set! g-pipeline pipeline)

  ;; Vertex buffer — host visible, written every frame
  (define buf-size (* MAX-VERTICES 32))
  (define buffer-info (VkBufferCreateInfo))
  (set! buffer-info.sType       VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO)
  (set! buffer-info.size        buf-size)
  (set! buffer-info.usage       VK_BUFFER_USAGE_VERTEX_BUFFER_BIT)
  (set! buffer-info.sharingMode VK_SHARING_MODE_EXCLUSIVE)
  (define vert-buf (VkBuffer))
  (vkCreateBuffer g-device &buffer-info 0 &vert-buf)
  (define memory-reqs (VkMemoryRequirements))
  (vkGetBufferMemoryRequirements g-device vert-buf &memory-reqs)
  (define alloc-info (VkMemoryAllocateInfo))
  (set! alloc-info.sType           VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO)
  (set! alloc-info.allocationSize  memory-reqs.size)
  (set! alloc-info.memoryTypeIndex
    (find-memory-type memory-reqs.memoryTypeBits
      (VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT ∨ VK_MEMORY_PROPERTY_HOST_COHERENT_BIT)))
  (define vert-mem (VkDeviceMemory))
  (vkAllocateMemory g-device &alloc-info 0 &vert-mem)
  (vkBindBufferMemory g-device vert-buf vert-mem 0)
  (set! g-vert-buffer vert-buf)
  (set! g-vert-memory vert-mem)

  (vkDestroyShaderModule g-device vert-mod 0)
  (vkDestroyShaderModule g-device frag-mod 0)
  (free stages)
  (free attrs)
  (free dyn-states)
  (show "Renderer pipeline created"))

;;; Frame lifecycle

(define (renderer-begin-frame)
  (set! g-vertex-count 0)
  (set! g-batch-count  0))

(define (renderer-end-frame [cmd :: VkCommandBuffer])
  (unless (g-vertex-count = 0)
    ;; Upload vertices
    (define byte-size (* g-vertex-count 32))
    (define mapped-num 0)
    (vkMapMemory g-device g-vert-memory 0 byte-size 0 &mapped-num)
    (memcpy mapped-num g-vertices byte-size)
    (vkUnmapMemory g-device g-vert-memory)

    ;; Set dynamic viewport and scissor
    (define vp (VkViewport))
    (set! vp.x        0.0)
    (set! vp.y        0.0)
    (set! vp.width    g-screen-w)
    (set! vp.height   g-screen-h)
    (set! vp.minDepth 0.0)
    (set! vp.maxDepth 1.0)
    (vkCmdSetViewport cmd 0 1 &vp)

    (define scissor (VkRect2D))
    (set! scissor.offset.x      0)
    (set! scissor.offset.y      0)
    (set! scissor.extent.width  g-screen-w)
    (set! scissor.extent.height g-screen-h)
    (vkCmdSetScissor cmd 0 1 &scissor)

    ;; Bind pipeline
    (vkCmdBindPipeline cmd VK_PIPELINE_BIND_POINT_GRAPHICS g-pipeline)

    ;; Push screen size
    (define screen-size (calloc 2 4))
    (set! (screen-size 0) g-screen-w)
    (set! (screen-size 4) g-screen-h)
    (vkCmdPushConstants cmd g-pipeline-layout
      VK_SHADER_STAGE_VERTEX_BIT 0 8 screen-size)
    (free screen-size)

    ;; Bind vertex buffer
    (define [offset :: I32] 0)
    (vkCmdBindVertexBuffers cmd 0 1 &g-vert-buffer &offset)

    ;; Draw each texture batch
    (for [i 0 g-batch-count]
      (define [b -> TextureBatch] (g-batches i))
      (define [tex -> Texture2D]  b.texture)
      (define vc    b.vertex-count)
      (define sv    b.start-vertex)
      (show "binding descSet: _" tex.descSet)
      (vkCmdBindDescriptorSets cmd VK_PIPELINE_BIND_POINT_GRAPHICS
        g-pipeline-layout 0 1 &tex.descSet 0 0)
      (vkCmdDraw cmd vc 1 sv 0))))

;;; Primitive: push one vertex into the CPU buffer

(define (push-vertex [x :: F32] [y :: F32]
                     [u :: F32] [v :: F32]
                     [c :: Color])
  (unless (g-vertex-count >= MAX-VERTICES)
    (define [vtx -> Vertex]
      (g-vertices g-vertex-count))
    (set! vtx.x x)
    (set! vtx.y y)
    (set! vtx.u u)
    (set! vtx.v v)
    (set! vtx.r c.r)
    (set! vtx.g c.g)
    (set! vtx.b c.b)
    (set! vtx.a c.a)
 (set! g-vertex-count (g-vertex-count + 1))))

;;; Internal: get or open a batch for a texture

(define (get-batch [tex -> Texture2D] -> I32)
  (define [result :: I32] -1)
  (if (g-batch-count > 0)
    (begin
      (define [last -> TextureBatch]
        (g-batches (g-batch-count - 1)))
      (if (last.texture = tex)
        (set! result (g-batch-count - 1)))))
  (if (result = -1)
    (begin
      (if (g-batch-count >= MAX-TEXTURES)
        (show "get-batch: too many texture batches")
        (begin
          (set! result g-batch-count)
          (define [b -> TextureBatch] (g-batches result))
          (set! b.texture      tex)
          (set! b.start-vertex g-vertex-count)
          (set! b.vertex-count 0)
          (set! g-batch-count (g-batch-count + 1))))))
  result)

;;; Draw a textured quad

(define (texture2D [x    :: F32] [y :: F32]
                   [w    :: F32] [h :: F32]
                   [tex -> Texture2D]
                   [tint :: Color])
  (if (tex.loaded = 0)
    (show "texture2D: texture not loaded")
    (begin
      (if ((g-vertex-count + 6) > MAX-VERTICES)
        (show "texture2D: vertex buffer full")
        (begin
          (define bi (get-batch tex))
          (push-vertex  x       y      0.0 0.0  tint)
          (push-vertex (x + w)  y      1.0 0.0  tint)
          (push-vertex (x + w) (y + h) 1.0 1.0  tint)
          (push-vertex  x       y      0.0 0.0  tint)
          (push-vertex (x + w) (y + h) 1.0 1.0  tint)
          (push-vertex  x      (y + h) 0.0 1.0  tint)
          (define [b -> TextureBatch]
            (g-batches bi))
          (set! b.vertex-count (b.vertex-count + 6)))))))

;;; Draw a single character, returns advance width

(define (draw-char [font -> Font]
                   [ch    :: I32]
                   [x     :: F32]
                   [y     :: F32]
                   [color :: Color] -> F32)
  (if ((ch < 32) or (ch > 126))
    0.0
    (begin
      (define ci  (font.chars ch))
      (define x0  (x + ci.bl))
      (define y0  (y - ci.bt))
      (define x1  (x0 + ci.bw))
      (define y1  (y0 + ci.bh))
      (define u0  ci.tx)
      (define v0  ci.ty)
      (define u1  (u0 + (ci.bw / 512.0)))
      (define v1  (v0 + (ci.bh / 512.0)))
      (define bi  (get-batch &font.texture))
      (push-vertex x0 y0  u0 v0  color)
      (push-vertex x1 y0  u1 v0  color)
      (push-vertex x1 y1  u1 v1  color)
      (push-vertex x0 y0  u0 v0  color)
      (push-vertex x1 y1  u1 v1  color)
      (push-vertex x0 y1  u0 v1  color)
      (define [b -> TextureBatch] (g-batches bi))
      (set! b.vertex-count (b.vertex-count + 6))
      ci.ax)))

;;; Draw a string

(define (draw-text [font -> Font]
                   [text  :: String]
                   [x     :: F32]
                   [y     :: F32]
                   [color :: Color])
  (define [cx :: F32] x)
  (define [i  :: I32] 0)
  (until ((text i) = 0)
    (set! cx (cx + (draw-char font (text i) cx y color)))
    (set! i  (i  + 1))))

;;; Draw a block cursor

(define (draw-cursor [font -> Font]
                     [x     :: F32]
                     [y     :: F32]
                     [color :: Color])
  ;; Use 'M' advance as cursor width, font metrics for height
  (define m   (font.chars 77))
  (define cw  m.ax)
  (define ch  (font.ascent + 0.0))
  (define cy  (y - ch))
  ;; Sample a solid white texel at UV (0,0) — top-left of atlas is empty
  (define u 0.0) (define v 0.0)
  (push-vertex  x        cy       u v  color)
  (push-vertex (x + cw)  cy       u v  color)
  (push-vertex (x + cw) (cy + ch) u v  color)
  (push-vertex  x        cy       u v  color)
  (push-vertex (x + cw) (cy + ch) u v  color)
  (push-vertex  x       (cy + ch) u v  color)
  (define bi (get-batch &font.texture))
  (define [b -> TextureBatch]  (g-batches bi))
  (set! b.vertex-count (b.vertex-count + 6)))

;;; Shutdown

(define (renderer-shutdown)
  (vkDestroyPipeline             g-device g-pipeline        0)
  (vkDestroyPipelineLayout       g-device g-pipeline-layout 0)
  (vkDestroyDescriptorSetLayout  g-device g-desc-set-layout 0)
  (vkDestroyBuffer               g-device g-vert-buffer     0)
  (vkFreeMemory                  g-device g-vert-memory     0)
  (free g-vertices)
  (free g-batches))
