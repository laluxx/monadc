;;; Renderer.mon --- 2D Vulkan renderer
;;
;; Author: Laluxx
;; Version: 0.0.1
;; Keywords: vulkan renderer 2D text graphics
;; Reference:
;; - https://vulkan-tutorial.com
;; - https://vkguide.dev
;;
;;; Commentary:
;;
;; Immediate-mode 2D renderer built on Vulkan.
;; Batches textured quads for text rendering and colored primitives.
;; Call (renderer-begin-frame) at the start of each frame, emit draw calls,
;; then (renderer-end-frame cmd) to submit. All geometry is flushed per-frame.
;;
;; Usage:
;;   (import Renderer)
;;   ;; after Vulkan is up:
;;   (set! g-device      my-device)
;;   (set! g-phys-device my-phys-device)
;;   (set! g-queue       my-queue)
;;   (renderer-create-pipeline my-render-pass)
;;
;;; Code:

import Font
;; import TextFragSpv
;; import TextVertSpv

include <vulkan/vulkan.h>
include <stdlib.h>
include <string.h>
include <stdio.h>

