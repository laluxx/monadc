;; The symplest Refinement Type
;; type Code List
;;   :doc "doc"
;;   :alias C
;     ^
; Types MUST start with a capital letter
; `Code` will inherit everything from list
; including the docstring if not specified.



type Natural { x ∈ Int | x >= 0 }
  :doc "Natural number type"
  :alias ℕ

(define (passedNatural? [x :: Natural] -> Bool)
  (Natural? x))


(show (passedNatural? 1)); passing -1 is a compile time ERROR

