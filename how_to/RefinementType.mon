;; TODO
;; type Even { x ∈ ℤ | ∃k ∈ ℤ, x = 2k }
;;   "Existential form."

;; `major-mode` v inserted with a double SPC
type Even { x ∈ Int | x % 2 = 0 }
  "Even integers"

(define (passedEven? [x :: Even] -> Bool)
  (Even? x))

(show (passedEven? 2))


type Positive { x ∈ Int | x > 0 }
  "Integers greater than zero"


(type PositiveEven
  { n ∈ Int
  | ((Positive? n) `and` (Even? n)) }
  "Positive even integers")

(define (passedPositiveEven? [x :: PositiveEven] -> Bool)
  (PositiveEven? x))

(show (passedPositiveEven? 2))

(type Email
  { s ∈ String
  | (and (s `contains?` "@")
         (s `contains?` ".")
         ((count s) `>` 5)
         (not (s `contains?` " "))) })

(define (passedEmail? [x :: Email] -> Bool)
  (Email? x))

(show (passedEmail? "ciao.@"))

(type CompanyEmail
  { s ∈ Email
  | (s `ends-with?` "@company.com") })

(define (passedCompanyEmail? [x :: CompanyEmail] -> Bool)
  (CompanyEmail? x))

(show (passedCompanyEmail? "porcodio@company.com"))
(show "TESTING")
(show ('(1 2 3) `ends-with?` 3))
(show ("ciao" `ends-with?` "ao"))
(show ([1 2 3] `ends-with?` 3))

(show ('(1 2 3) `ends-with?` '(2 3)))
(show ('[1 2 3] `ends-with?` [2 3]))
(show ("ciao" `ends-with?` 'o'))
