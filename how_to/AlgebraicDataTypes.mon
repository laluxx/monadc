;; show √3


(layout Vec3
  [x :: Float]
  [y :: Float]
  [z :: Float])


class Pow a where
  type Result a
  (^) :: a -> Int -> Result a


instance Pow Float where
  type Result Float = Float
  (base ^ exp) =>
    (if (exp = 0) 1.0
        (if (exp > 0)
            (base * (base ^ (exp - 1)))
            (1.0 / (base ^ (0 - exp)))))


instance Pow Vec3 where
  type Result Vec3 = Float
  (v ^ exp) =>
    ((v.x ^ exp) + (v.y ^ exp) + (v.z ^ exp))


;; DONE Make this compile
define normalize :: Vec3 -> Vec3
  v[x y z] -> def len √v²
                    x   y   z
              Vec3 ─── ─── ───
                   len len len


define v Vec3 3.0 4.0 5.0

show v
(newline)
show normalize v



