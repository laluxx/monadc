;; show until (> 10) (+ 1) 5

define until :: (a -> Bool) -> (a -> a) -> a -> a
  p f                -> go
  where
    go x | p x       -> x
         | otherwise -> go (f x)


define newline -> a
  show ""


define abs :: Float -> Float
  x -> if x < 0.0 then 0.0 - x else x


define max :: a -> a -> a
  x y | x >= y    -> x
      | otherwise -> y


define sqrt :: Float -> Float
  x | x <= 0    -> 0
    | otherwise -> until goodEnough? improve (x / 2)
    where
      improve    g -> (g + x / g) / 2
      goodEnough g -> (< (abs (- (improve g) g)) (* 1e-12 (max 1 g)))

