



define type-id :: ∀a -> a
  _ -> a


data T = A | B | C deriving [Bounded Enum Show]

;;                       Optional semicolon
;;                               ↓
define toEnumSafe :: ∀ t. [Enum t, Bounded t] => Int -> Maybe t
  n | >= 0 and <= size -> Just (toEnum n)
    | otherwise        -> Nothing
    where
      size = fromEnum (maxBound :: t) - fromEnum (minBound :: t)
