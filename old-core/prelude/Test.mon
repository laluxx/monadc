

;; define all? :: (a -> Bool) -> [a] -> Bool
;;   _ []            -> True
;;   p [x|xs]
;;       | p x       -> all? p xs
;;       | otherwise -> False

;; define both :: . (a -> Bool) -> (a -> Bool)
;;   preds -> (lambda (x) (all? (lambda (p) (p x)) preds))



define filter :: (a -> Bool) -> [a] -> [a]
  _ []            -> []
  p [x|xs]
      | p x       -> (x ++ (filter p xs))
      | otherwise -> filter p xs


;; TODO the fix should be entirely in wisp, just put the
;; parentheses right and ti can work like the one below..
;; define qsort :: [a] -> [a]
;;   []    -> []
;;   [h|t] -> qsort (filter (<= h) t)
;;              ++ [h]
;;              ++ qsort (filter (> h) t)



(define (qsort [a] -> [a])
  [] -> []
  [h|t] -> ((qsort (filter (<= h) t))
               ++ [h]
               ++ (qsort (filter (> h) t))))

show (qsort '(2 1 3 20 10 1 22 3))
show (qsort "lkdsaj923928udksjals")

