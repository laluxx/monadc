;;; Maybe.mon --- Optional values

;; Author: Laluxx
;; Version: 1.0.0
;; Keywords: Data.Maybe maybe optional functor applicative monad

;;; Commentary:

;; Maybe is a real algebraic data type. It must never be encoded as [] / [x]
;; in public APIs. Use Nothing for absence and Just x for presence.

;;; Code:

import Class

module Data.Maybe
  [Maybe Nothing Just
   maybe fromMaybe fromJust
   just? nothing? isJust isNothing
   mapMaybe catMaybes maybeToList listToMaybe
   safe-head safe-tail safe-last safe-init
   firstJust orElse]


data Maybe a = Nothing | Just a


