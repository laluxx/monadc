;;; Coll.mon --- Core collection and sequence utilities

;; Author: Laluxx
;; Version: 0.5.0
;; Keywords: prelude collections sequence list haskell

;;; Commentary:

;; The collection prelude. Surface type [a] is the abstract sequence/collection
;; interface. Concrete arrays are spelled [Int], [Float], ... by the type parser;
;; tuple/list product spelling is parenthesized: (Int) or (Int, Bool).
;; Public APIs use Maybe/Either for partiality; empty/singleton lists are never
;; used to encode optional values.

;;; Code:

import Class
import Numeric
import Data.Maybe

module Coll
 [naturals positives evens odds
  cons head tail last init uncons
  null? empty? length singleton?
  take drop splitAt takeEnd dropEnd
  ;; takeWhile dropWhile span partition
  map foreach filter reject mapIndexed
  find findIndex elemIndex indexOf lookup lookupWithDefault
  any? all? none?
  foldl foldl' foldl1 foldr foldr1
  zip zipWith zipWith3 unzip unzip3
  reverse append snoc concat flatten concatMap concatMapMaybe
  replicate repeat iterate
  intersperse intercalate transpose
  inits tails
  and-list? or-list? sum product maximum minimum maximumBy minimumBy
  clamp
  elem? contains? notElem?
  delete deleteBy nub nubBy difference union intersect
  insertSorted insertBy sort sortBy
  ;; group groupBy
  countWhere count elemCount
  isPrefixOf? isSuffixOf? isInfixOf?
  range rangeBy]


;;; Canonical infinite enumerations. These require range syntax support.


define [naturals  :: List] ⌜0..  ⌝ :doc "The infinite list of natural numbers: 0, 1, 2, ..."
define [positives :: List] ⌜1..  ⌝ :doc "The infinite list of positive integers: 1, 2, 3, ..."
define [evens     :: List] ⌜0,2..⌝ :doc "The infinite list of even natural numbers: 0, 2, 4, ..."
define [odds      :: List] ⌜1,3..⌝ :doc "The infinite list of positive odd integers: 1, 3, 5, ..."



;;; Constructors and partial/safe accessors


define cons :: a -> [a] -> [a]
  :doc "Prepend X to XS."
  x xs -> [x | xs]


define head :: [a] -> a
  :doc "Return the first element. Partial: fails on an empty sequence."
  [x|_] -> x
  []    -> error "head: empty sequence"

define tail :: [a] -> [a]
  :doc "Return all elements after the first. Partial: fails on an empty sequence."
  [_|xs] -> xs
  []     -> error "tail: empty sequence"


define last :: [a] -> a
  :doc "Return the last element. Partial: fails on an empty sequence."
  [x]    -> x
  [_|xs] -> last xs
  []     -> error "last: empty sequence"


define init :: [a] -> [a]
  :doc "Return all but the last element. Partial: fails on an empty sequence."
  [_]    -> []
  [x|xs] -> [x | init xs]
  []     -> error "init: empty sequence"


define uncons :: [a] -> Maybe (a, [a])
  :doc "Return Just (head, tail) or Nothing for an empty sequence."
  []     -> Nothing
  [x|xs] -> Just (x, xs)


;; Deferred: the local `where` helper captured by `fmap` currently lowers to an
;; unresolved imported partial closure during core bootstrap.
;; define unsnoc :: [a] -> Maybe ([a], a)
;;   :doc "Return Just (init, last) or Nothing for an empty sequence."
;;   []     -> Nothing
;;   [x]    -> Just ([], x)
;;   [x|xs] -> fmap prepend (unsnoc xs)
;;     where
;;       prepend (front, end) -> ([x | front], end)


;;; Size and emptiness


define null? :: [a] -> Bool
  :doc "Return True when XS is empty."
  [] -> True
  _  -> False


define empty? :: [a] -> Bool
  :doc "Return True when XS is empty."
  [] -> True
  _  -> False


define length :: [a] -> Int
  :doc "Return the number of elements in XS."
  []     -> 0
  [_|xs] -> 1 + length xs


define singleton? :: [a] -> Bool
  :doc "Return True when XS has exactly one element."
  [_] -> True
  _   -> False


;;; Slicing


define take :: Int -> [a] -> [a]
  n _    |   <= 0   -> []
  _ []              -> []
  n [x|xs]          -> [x | take (n - 1) xs]
  :doc "Return the first N elements, or fewer if XS is shorter."


define drop :: Int -> [a] -> [a]
  n xs     | n <= 0 -> xs
  _ []              -> []
  n [_|xs]          -> drop (n - 1) xs
  :doc "Drop the first N elements."


define splitAt :: Int -> [a] -> [[a]]
  n xs -> [(take n xs) | [(drop n xs) | []]]
  :doc "Split XS at index N."


define takeEnd :: Int -> [a] -> [a]
  n xs | n <= 0    -> []
       | otherwise -> drop ((length xs) - n) xs
  :doc "Return the last N elements."


define dropEnd :: Int -> [a] -> [a]
  n xs | n <= 0    -> xs
       | otherwise -> take ((length xs) - n) xs
  :doc "Drop the last N elements."


