;;; Mapping and filtering


define map :: (a -> b) -> [a] -> [b]
  :doc "Map F over XS."
  _ []     -> []
  f [x|xs] -> [(f x) | map f xs]


define foreach :: (a -> b) -> [a] -> [b]
  :alias forEach
  :doc "Alias-style name for map, kept as metadata on the canonical binding."
  f xs -> map f xs


define mapIndexedFrom :: (Int -> a -> b) -> Int -> [a] -> [b]
  _ _ []     -> []
  f n [x|ys] -> [(f n x) | mapIndexedFrom f (n + 1) ys]


define mapIndexed :: (Int -> a -> b) -> [a] -> [b]
  :doc "Map F over XS with a zero-based index."
  f xs -> mapIndexedFrom f 0 xs


define filter :: (a -> Bool) -> [a] -> [a]
  :doc "Keep elements satisfying P."
  _ [] -> []
  p [x|xs]
      | p x       -> [x | filter p xs]
      | otherwise -> filter p xs


define reject :: (a -> Bool) -> [a] -> [a]
  :doc "Remove elements satisfying P."
  _ [] -> []
  p [x|xs]
      | p x       -> reject p xs
      | otherwise -> [x | reject p xs]


define find :: (a -> Bool) -> [a] -> Maybe a
  :doc "Return the first element satisfying P, or Nothing."
  _ [] -> Nothing
  p [x|xs]
      | p x       -> Just x
      | otherwise -> find p xs


define findIndexFrom :: (a -> Bool) -> Int -> [a] -> Maybe Int
  _ _ [] -> Nothing
  p n [x|ys]
         | p x       -> Just n
         | otherwise -> findIndexFrom p (n + 1) ys


define findIndex :: (a -> Bool) -> [a] -> Maybe Int
  :doc "Return the first index whose element satisfies P, or Nothing."
  p xs -> findIndexFrom p 0 xs


define elemIndex :: Eq a => a -> [a] -> Maybe Int
  :alias indexOf
  :doc "Return the index of X in XS, or Nothing."
  x xs -> findIndex (= x) xs


define lookup :: Eq a => a -> [(a, b)] -> Maybe b
  :doc "Look up KEY in an association sequence."
  _ [] -> Nothing
  key [(k, v)|rest]
             | key = k   -> Just v
             | otherwise -> lookup key rest


define lookupWithDefault :: Eq a => b -> a -> [(a, b)] -> b
  :doc "Look up KEY, returning DEFAULT when absent."
  default key xs -> fromMaybe default (lookup key xs)


;;; Predicates


define any? :: (a -> Bool) -> [a] -> Bool
  :doc "Return True if any element satisfies P."
  _ [] -> False
  p [x|xs]
      | p x       -> True
      | otherwise -> any? p xs


define all? :: (a -> Bool) -> [a] -> Bool
  :doc "Return True if all elements satisfy P."
  _ [] -> True
  p [x|xs]
      | p x       -> all? p xs
      | otherwise -> False


define none? :: (a -> Bool) -> [a] -> Bool
  :doc "Return True if no element satisfies P."
  p xs -> not (any? p xs)


;;; Folds and scans


define foldl :: (b -> a -> b) -> b -> [a] -> b
  :doc "Left fold over XS."
  _ acc []     -> acc
  f acc [x|xs] -> foldl f (f acc x) xs


define foldl' :: (b -> a -> b) -> b -> [a] -> b
  :doc "Strict left fold. Currently aliases foldl until strictness is explicit."
  f acc xs -> foldl f acc xs


define foldl1 :: (a -> a -> a) -> [a] -> a
  :doc "Left fold requiring a non-empty sequence."
  _ []     -> error "foldl1: empty sequence"
  f [x|xs] -> foldl f x xs


define foldr :: (a -> b -> b) -> b -> [a] -> b
  :doc "Right fold over XS."
  _ acc []     -> acc
  f acc [x|xs] -> f x (foldr f acc xs)


define foldr1 :: (a -> a -> a) -> [a] -> a
  :doc "Right fold requiring a non-empty sequence."
  _ []  -> error "foldr1: empty sequence"
  _ [x] -> x
  f [x|xs] -> f x (foldr1 f xs)


