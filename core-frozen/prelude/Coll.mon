;;   :doc "Group adjacent equal elements according to EQ."
;;   _ [] -> []
;;   eq [x|xs] -> [(cons x (takeWhile (eq x) xs)) | groupBy eq (dropWhile (eq x) xs)]
;;
;; define group :: [Int] -> [[Int]]
;;   :doc "Group adjacent equal elements."
;;   xs -> groupBy (lambda (a b) (a = b)) xs


;;; Counting and containment


define countWhere :: (a -> Bool) -> [a] -> Int
  :doc "Count elements satisfying P."
  p xs -> length (filter p xs)


define count :: [a] -> Int
  :doc "Alias-style name for length."
  xs -> length xs


define elemCount :: Int -> [Int] -> Int
  :doc "Count occurrences of X in XS."
  _ [] -> 0
  x [y|ys]
      | (= x y)   -> 1 + elemCount x ys
      | otherwise -> elemCount x ys


define isPrefixOf? :: [Int] -> [Int] -> Bool
  :doc "Return True if PREFIX is a prefix of XS."
  [] _ -> True
  _ [] -> False
  [p|ps] [x|xs]
           | (= p x)   -> isPrefixOf? ps xs
           | otherwise -> False


define isSuffixOf? :: [Int] -> [Int] -> Bool
  :doc "Return True if SUFFIX is a suffix of XS."
  suffix xs -> isPrefixOf? (reverse suffix) (reverse xs)


define isInfixOf? :: [Int] -> [Int] -> Bool
  :doc "Return True if NEEDLE occurs contiguously inside HAYSTACK."
  [] _ -> True
  _ [] -> False
  needle [x|rest]
           | isPrefixOf? needle (cons x rest) -> True
           | otherwise                        -> isInfixOf? needle rest


;;; Ranges and windows


define range :: Int -> Int -> [Int]
  lo hi | lo > hi    -> []
        | otherwise  -> [lo | range (lo + 1) hi]
  :doc "Return the inclusive integer range LO..HI."


define rangeBy :: Int -> Int -> Int -> [Int]
  step lo hi
    | (= step 0)           -> error "rangeBy: zero step"
    | step > 0 and lo > hi -> []
    | step < 0 and lo < hi -> []
    | otherwise            -> [lo | rangeBy step (lo + step) hi]
  :doc "Return an inclusive integer range using STEP."


;; Deferred: nested collection results are currently flattened by the reader
;; and collection inferencer (`[[Int]]` lowers to `Coll`), which makes these
;; helpers typecheck as flat Int collections instead of collections of chunks.
;; Re-enable with a focused nested-collection regression.
