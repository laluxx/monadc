;; define windowsOf :: Int -> [Int] -> [[Int]]
;;   n xs | n <= 0              -> error "windowsOf: non-positive size"
;;        | length xs < n       -> []
;;        | otherwise           -> [(take n xs) | windowsOf n (tail xs)]
;;   :doc "Return all contiguous windows of size N."


tests
  assert-eq (length [1 2 3])       3 "Coll length"
  assert-eq (take 2 [1 2 3])       [1 2] "Coll take"
  assert-eq (drop 2 [1 2 3])       [3] "Coll drop"
  assert-eq (map (+ 1) [1 2 3])    [2 3 4] "Coll map"
  assert-eq (filter (> 1) [1 2 3]) [2 3] "Coll filter"
  ;; Deferred: cross-module Maybe equality for Coll.find results still hits the
  ;; raw ADT/runtime equality boundary.
  ;; assert-eq (find (> 2) [1 2 3])   (Just 3) "Coll find"
  ;; assert-eq (find (> 9) [1 2 3])   Nothing "Coll find Nothing"
  assert-eq (sum [1 2 3])              6 "Coll sum"
  assert-eq (reverse ⌜1 2 3⌝)      ⌜3 2 1⌝ "Coll reverse"
  assert-eq (append ⌜1 2⌝ ⌜3⌝)     ⌜1 2 3⌝ "Coll append"
  assert-eq (replicate 3 7)        ⌜7 7 7⌝ "Coll replicate"
  assert-eq (zip ⌜1 2⌝ ⌜3 4⌝)      [(1, 3) | [(2, 4) | ⌜⌝]] "Coll zip"
  assert-eq (nub ⌜1 2 1 3 2⌝)      ⌜1 2 3⌝ "Coll nub"
  ;; Deferred: sort depends on the remaining comparator/list recursion edge.
  ;; assert-eq (sort ⌜3 1 2⌝)         ⌜1 2 3⌝ "Coll sort"
