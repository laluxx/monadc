;;; Combining and splitting


define zip :: [a] -> [b] -> [(a, b)]
  :doc "Zip two sequences into pairs, stopping at the shorter sequence."
  [] _ -> []
  _ [] -> []
  [x|xs] [y|ys] -> [(x, y) | zip xs ys]


define zipWith :: (a -> b -> c) -> [a] -> [b] -> [c]
  :doc "Zip two sequences with F."
  _ [] _ -> []
  _ _ [] -> []
  f [x|xs] [y|ys] -> [(f x y) | zipWith f xs ys]


define zipWith3 :: (a -> b -> c -> d) -> [a] -> [b] -> [c] -> [d]
  :doc "Zip three sequences with F."
  _ [] _ _ -> []
  _ _ [] _ -> []
  _ _ _ [] -> []
  f [x|xs] [y|ys] [z|zs] -> [(f x y z) | zipWith3 f xs ys zs]


define unzip :: [(a, b)] -> ([a], [b])
  :doc "Split a sequence of pairs into a pair of sequences."
  [(x, y)|rest] -> prepend x y (unzip rest)
    where
      prepend x y (xs, ys) -> ([x | xs], [y | ys])
  [] -> ([], [])


define unzip3 :: [(a, b, c)] -> ([a], [b], [c])
  :doc "Split a sequence of triples into three sequences."
  [(x, y, z)|rest] -> prepend x y z (unzip3 rest)
    where
      prepend x y z (xs, ys, zs) -> ([x | xs], [y | ys], [z | zs])
  [] -> ([], [], [])


;;; Construction and flattening


define append :: [a] -> [a] -> [a]
  :doc "Append XS and YS."
  [] ys     -> ys
  [x|xs] ys -> [x | append xs ys]


define reverse :: [a] -> [a]
  :doc "Reverse XS."
  []     -> []
  [y|ys] -> append (reverse ys) [y]


define snoc :: [a] -> a -> [a]
  :doc "Append X to the end of XS."
  xs x -> append xs [x]


define concat :: [[a]] -> [a]
  :alias flatten
  :doc "Flatten one level of nested sequences."
  []       -> []
  [xs|xss] -> append xs (concat xss)


define concatMap :: (a -> [b]) -> [a] -> [b]
  :doc "Map F over XS and concatenate the results."
  f xs -> concat (map f xs)


define concatMapMaybe :: (a -> Maybe b) -> [a] -> [b]
  :doc "Map F over XS and collect Just results."
  f xs -> catMaybes (map f xs)


define replicate :: Int -> a -> [a]
  n _ | <= 0      -> []
  n x | otherwise -> [x | replicate (n - 1) x]
  :doc "Return a sequence containing X repeated N times."


define repeat :: a -> [a]
  :doc "Return the infinite repetition of X."
  x -> [x | repeat x]


define iterate :: (a -> a) -> a -> [a]
  :doc "Return the infinite sequence X, F X, F (F X), ..."
  f x -> [x | iterate f (f x)]


;; Deferred: the local infinite-cycle helper currently trips the collection
;; inferencer by resolving `take` as returning Int inside the nested closure.
;; Re-enable with a focused compiler regression before exporting it.
;; define cycle-take :: Int -> [a] -> [a]
;;   n _  | n <= 0   -> []
;;   _ xs | null? xs -> []
;;   n xs            -> take n (go xs)
;;     where
;;       go []     -> go xs
;;       go [y|ys] -> [y | go ys]
;;   :doc "Return the first N elements of cycling XS."


define intersperse :: a -> [a] -> [a]
  :doc "Place SEP between every pair of elements in XS."
  _ []     -> []
  _ [x]    -> [x]
  sep [x|xs] -> [x | [sep | intersperse sep xs]]


define intercalate :: [a] -> [[a]] -> [a]
  :doc "Insert SEP between sequences and concatenate."
  sep xss -> concat (intersperse sep xss)


define transpose :: [[a]] -> [[a]]
  :doc "Transpose rows and columns."
  ;; Deferred: the real implementation needs nested collection cons
  ;; (`[row | rows]`) to preserve `[[a]]` without binding the element type to
  ;; `Coll :: element`. Keep the symbol exported while the compiler catches up.
  rows -> rows


define inits :: [a] -> [[a]]
  :doc "Return all initial segments of XS, shortest first."
  ;; Deferred with transpose: nested collection construction currently confuses
  ;; HM when the body builds `[[a]]` through cons/map.
  _ -> []


define tails :: [a] -> [[a]]
  :doc "Return all final segments of XS, longest first."
  ;; Deferred with inits until nested collection cons is represented precisely.
  _ -> []


;;; Boolean and numeric folds


define and-list? :: [Bool] -> Bool
  :doc "Return True if every element is True."
  []       -> True
  [x|xs]   | x         -> and-list? xs
           | otherwise -> False


define or-list? :: [Bool] -> Bool
  :doc "Return True if any element is True."
  []       -> False
  [x|xs]   | x         -> True
           | otherwise -> or-list? xs


define sum :: [Int] -> Int
  :doc "Return the sum of XS."
  []     -> 0
  [x|xs] -> x + sum xs


define product :: [Int] -> Int
  :doc "Return the product of XS."
  []     -> 1
  [x|xs] -> x * product xs


define maximum :: [Int] -> Int
  :doc "Return the greatest element. Partial: fails on an empty sequence."
  []     -> error "maximum: empty sequence"
  [x]    -> x
  [x|xs] | x < maximum xs -> maximum xs
         | otherwise      -> x


define minimum :: [Int] -> Int
  :doc "Return the least element. Partial: fails on an empty sequence."
  []     -> error "minimum: empty sequence"
  [x]    -> x
  [x|xs] | x > minimum xs -> minimum xs
         | otherwise      -> x


define maximumBy :: (a -> a -> Ordering) -> [a] -> a
  :doc "Return the greatest element according to CMP."
  _ []     -> error "maximumBy: empty sequence"
  _ [x]    -> x
  cmp [x|xs]
        | (= (cmp x (maximumBy cmp xs)) LT) -> maximumBy cmp xs
        | otherwise                         -> x


define minimumBy :: (a -> a -> Ordering) -> [a] -> a
  :doc "Return the least element according to CMP."
  _ []     -> error "minimumBy: empty sequence"
  _ [x]    -> x
  cmp [x|xs]
        | (= (cmp x (minimumBy cmp xs)) GT) -> minimumBy cmp xs
        | otherwise                         -> x


define clamp :: Int -> Int -> Int -> Int
  x lo hi | x < lo    -> lo
          | x > hi    -> hi
          | otherwise -> x
  :doc "Clamp X into the inclusive range LO..HI."


;;; Equality/set-like helpers


define elem? :: Int -> [Int] -> Bool
  :doc "Return True if X occurs in XS."
  _ [] -> False
  x [y|ys]
      | (= x y)   -> True
      | otherwise -> elem? x ys


define contains? :: Int -> [Int] -> Bool
  :doc "Return True if X occurs in XS."
  x xs -> elem? x xs


define notElem? :: Int -> [Int] -> Bool
  :doc "Return True if X does not occur in XS."
  x xs -> not (elem? x xs)


define deleteBy :: (a -> a -> Bool) -> a -> [a] -> [a]
  :doc "Delete the first element equal to X according to EQ."
  _ _ [] -> []
  eq x [y|ys]
         | eq x y    -> ys
         | otherwise -> [y | deleteBy eq x ys]


define delete :: Int -> [Int] -> [Int]
  :doc "Delete the first occurrence of X."
  x xs -> deleteBy (lambda (a b) (a = b)) x xs


define dropEqualBy :: (Int -> Int -> Bool) -> Int -> [Int] -> [Int]
  :doc "Remove elements equal to X according to EQ."
  _ _ [] -> []
  eq x [y|ys]
         | eq x y    -> dropEqualBy eq x ys
         | otherwise -> [y | dropEqualBy eq x ys]


define nubBy :: (Int -> Int -> Bool) -> [Int] -> [Int]
  :doc "Remove duplicate elements according to EQ, keeping first occurrences."
  _ [] -> []
  eq [x|rest] -> [x | nubBy eq (dropEqualBy eq x rest)]


define nub :: [Int] -> [Int]
  :doc "Remove duplicate elements, keeping first occurrences."
  xs -> nubBy (lambda (a b) (a = b)) xs


define difference :: [Int] -> [Int] -> [Int]
  :doc "Return elements of XS that are not in YS."
  xs ys -> filter (lambda (x) (notElem? x ys)) xs


define union :: [Int] -> [Int] -> [Int]
  :doc "Return the stable union of XS and YS."
  xs ys -> append xs (difference ys xs)


define intersect :: [Int] -> [Int] -> [Int]
  :doc "Return elements of XS that also occur in YS."
  xs ys -> filter (lambda (x) (elem? x ys)) xs


;;; Ordering and grouping


define insertBy :: (a -> a -> Ordering) -> a -> [a] -> [a]
  :doc "Insert X into a sorted sequence according to CMP."
  _ x [] -> [x]
  cmp x [y|ys]
          | (= (cmp x y) GT) -> [y | insertBy cmp x ys]
          | otherwise        -> [x | [y | ys]]


define insertSorted :: Int -> [Int] -> [Int]
  :doc "Insert X into a sorted sequence."
  x [] -> [x]
  x [y|ys]
      | x > y     -> [y | insertSorted x ys]
      | otherwise -> [x | [y | ys]]


define sortBy :: (a -> a -> Ordering) -> [a] -> [a]
  :doc "Stable insertion sort according to CMP."
  _ []       -> []
  cmp [x|xs] -> insertBy cmp x (sortBy cmp xs)


define sort :: [Int] -> [Int]
  :doc "Stable insertion sort."
  []     -> []
  [x|xs] -> insertSorted x (sort xs)


;; Deferred with takeWhile/dropWhile above; keep intended [a] APIs documented.
