;; TEST-ID: tests.wisp.rt-wisp-define-typed-value-sugar
;; TEST-CONTEXT: monadc.context.wisp.define-typed-value-sugar
;; TEST-PURPOSE: Wisp value definitions accept bracketed and unbracketed type annotations.
;; TEST-ATOM: define name :: Type value desugars to the Lisp-layer [name :: Type] binding form.
;; TEST-EXPECT: compile, run
module Main
define [a :: Int] 1
define [b : Int] 2
define c :: Int 3
show a
show b
show c
