;; TEST-ID: tests.wisp.rt-wisp-define-parenthesized-signature
;; TEST-CONTEXT: monadc.context.wisp.define-parenthesized-signature
;; TEST-PURPOSE: Bare Wisp define accepts a parenthesized Lisp-style function header.
;; TEST-ATOM: define (f [n : Int] [xs : Arr] -> Int) keeps pattern clauses attached to the second argument.
;; TEST-EXPECT: compile, run
module Main
define (firstItem [n : Int] [xs : Arr] -> Int)
  _ []     -> 0
  n [x|xs] -> x
show (firstItem 9 [7 8])
