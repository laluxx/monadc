;; TEST-ID: tests.wisp.rt-wisp-lists
;; TEST-CONTEXT: monadc.context.wisp.lists
;; TEST-PURPOSE: Wisp list operations work
;; TEST-ATOM: car/cdr/nil?/empty? on quoted lists
;; TEST-EXPECT: compile, run
module Main
define xs '(1 2 3)
show car xs
show cdr xs
define ys '(10 20)
show xs ++ ys
show empty? xs
show nil? xs
