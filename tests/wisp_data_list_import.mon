;; TEST-CONTEXT: monadc.context.core-libs.coll, monadc.context.module.path-resolution

import Coll

tests
  assert-eq ([].null?)                               True      "Coll import exposes null?"
  assert-eq (show ((list 1 2 3 4).drop 2))          "(3 4)"   "Coll import exposes drop"
  assert-eq ((list 1 2 3 4 5).length)               5         "Coll import exposes length"
  assert-eq (show ((list 1 2 3).reverse))           "(3 2 1)" "Coll import exposes reverse"
  assert-eq ((list 5 6 7).nth 1)                    6         "Coll import exposes nth"
  assert-eq (foldl (lambda (acc x) (+ acc x)) 0 (list 1 2 3 4)) 10 "Coll import exposes foldl"
