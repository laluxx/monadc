name: complex_do_inside_add_left_operand_erases_setup
section: control-do
tier: stable
kind: law
features: arithmetic, control, do, equality, logic, set
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, codegen.runtime_call, codegen.sequence, infer.arithmetic, infer.equality, infer.logic, reader.ast_do, runtime.set
uses-atoms: atom.control.do, atom.core.equality, atom.logic.and, atom.logic.not, atom.logic.or
