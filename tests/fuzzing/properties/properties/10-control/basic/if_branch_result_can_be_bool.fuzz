name: if_branch_result_can_be_bool
section: control
tier: stable
kind: law
features: arithmetic, control, equality, if, phi, predicate
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.predicate_dispatch, infer.arithmetic, infer.equality, infer.if_phi, infer.type_predicate, reader.ast_if
uses-atoms: atom.control.if, atom.core.equality, atom.infer.predicate
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates
signal: medium
corpus-role: semantic-law
args: cond:Bool a:Int b:Int
type: Bool
expect: True
description: A Bool-returning if expression must be unaffected by passing its condition through the typed Bool identity helper.
law: (= (if {cond} (fuzz-lt? {a} {b}) (fuzz-gte? {a} {b})) (if (fuzz-bool-id? {cond}) (fuzz-lt? {a} {b}) (fuzz-gte? {a} {b})))
