name: structured_v9_loop_while_adds_branch_value_3_times
section: control-loop-mutation-v9
tier: stable
kind: law
features: arithmetic, array, array-index, begin, comparison, control, do, env, equality, if, mutation, phi, set, set!, while, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.branch_phi, codegen.comparison_dispatch, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.runtime_call, codegen.sequence, codegen.set_bang, codegen.store, codegen.while_loop, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.comparison, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, infer.loop, infer.mutation, reader.array_literal, reader.ast_begin, reader.ast_do, reader.ast_if, runtime.set
uses-atoms: atom.binding.set-bang, atom.binding.with, atom.control.begin, atom.control.do, atom.control.if, atom.core.equality, atom.core.multiply, atom.core.order.lt, atom.core.plus, atom.runtime.array
related-properties: signal_v13_atom_array_index_valid, signal_v13_atom_do_last_value, signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates, signal_v13_atom_lt_transitive, signal_v13_atom_multiply_associative, signal_v13_atom_multiply_commutative, signal_v13_atom_multiply_identity_one, signal_v13_atom_plus_associative, signal_v13_atom_plus_commutative, signal_v13_atom_plus_identity_zero, signal_v13_atom_with_substitution
signal: medium
corpus-role: semantic-law
args: p:Bool a:Int b:Int c:Int
type: Bool
expect: True
description: while loop must preserve loop-carried accumulator state across 3 iterations with branch-selected increment.
law: (= (with [i 0 acc {a}] (do (while (< i 3) (begin (set! acc (+ acc (if {p} {b} {c}))) (set! i (+ i 1)))) acc)) (+ {a} (* (if {p} {b} {c}) 3)))
