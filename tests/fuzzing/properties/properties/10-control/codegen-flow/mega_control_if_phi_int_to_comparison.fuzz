name: mega_control_if_phi_int_to_comparison
section: codegen-control-flow
tier: stable
kind: law
features: arithmetic, codegen, comparison, equality, if, phi
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.comparison_dispatch, codegen.equality_dispatch, codegen.if_phi, infer.arithmetic, infer.comparison, infer.equality, infer.if_phi, reader.ast_if
uses-atoms: atom.codegen.dispatch, atom.control.if, atom.core.equality, atom.core.order.lt
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates, signal_v13_atom_lt_transitive
signal: medium
corpus-role: semantic-law
args: p:Bool a:Int b:Int c:Int
type: Bool
expect: True
description: Int PHI from if must feed comparison dispatch.
law: (= (< (if {p} {a} {b}) {c}) (if {p} (< {a} {c}) (< {b} {c})))
