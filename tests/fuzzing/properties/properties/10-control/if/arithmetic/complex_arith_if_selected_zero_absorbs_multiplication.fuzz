name: complex_arith_if_selected_zero_absorbs_multiplication
section: arithmetic-if
tier: stable
kind: law
features: arithmetic, equality, if, logic, phi
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.logic_dispatch, infer.arithmetic, infer.equality, infer.if_phi, infer.logic, reader.ast_if
uses-atoms: atom.control.if, atom.core.equality, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates
signal: medium
corpus-role: semantic-law
args: cond:Bool a:Int b:Int
type: Bool
expect: True
description: Multiplication by an if-selected zero should produce zero regardless of the other branch path.
law: (= (fuzz-mul {a} (if {cond} 0 (fuzz-sub {b} {b}))) 0)
