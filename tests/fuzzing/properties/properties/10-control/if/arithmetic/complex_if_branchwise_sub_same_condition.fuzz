name: complex_if_branchwise_sub_same_condition
section: control-if-arithmetic
tier: stable
kind: law
features: arithmetic, control, equality, if, phi
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, infer.arithmetic, infer.equality, infer.if_phi, reader.ast_if
uses-atoms: atom.control.if, atom.core.equality
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates
signal: medium
corpus-role: semantic-law
args: cond:Bool a:Int b:Int c:Int d:Int
type: Bool
expect: True
description: Subtracting two if expressions with the same condition must choose the branchwise difference.
law: (= (fuzz-sub (if {cond} {a} {b}) (if {cond} {c} {d})) (if {cond} (fuzz-sub {a} {c}) (fuzz-sub {b} {d})))
