name: complex_if_compare_common_right_lt
section: control-if-order
tier: stable
kind: law
features: arithmetic, control, equality, if, logic, phi, predicate
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.logic_dispatch, codegen.predicate_dispatch, infer.arithmetic, infer.equality, infer.if_phi, infer.logic, infer.type_predicate, reader.ast_if
uses-atoms: atom.control.if, atom.core.equality, atom.infer.predicate, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates
signal: medium
corpus-role: semantic-law
args: cond:Bool common:Int a:Int b:Int
type: Bool
expect: True
description: Less-than from an if expression to a common right operand must choose branchwise comparisons.
law: (= (fuzz-lt? (if {cond} {a} {b}) {common}) (if {cond} (fuzz-lt? {a} {common}) (fuzz-lt? {b} {common})))
