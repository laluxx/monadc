name: mega_arith_mul_if_operand_phi
section: codegen-arith-phi
tier: stable
kind: law
features: arithmetic, codegen, equality, if, logic, phi
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.logic_dispatch, infer.arithmetic, infer.equality, infer.if_phi, infer.logic, reader.ast_if
uses-atoms: atom.codegen.dispatch, atom.control.if, atom.core.equality, atom.core.multiply, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates, signal_v13_atom_multiply_associative, signal_v13_atom_multiply_commutative, signal_v13_atom_multiply_identity_one
