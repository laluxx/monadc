name: complex_combo_min_max_under_same_if_condition
section: combo
tier: stable
kind: law
features: arithmetic, combo, equality, if, phi
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, infer.arithmetic, infer.equality, infer.if_phi, reader.ast_if
uses-atoms: atom.control.if, atom.core.equality
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates
signal: medium
corpus-role: semantic-law
args: cond:Bool a:Int b:Int c:Int d:Int
type: Bool
expect: True
description: Min and max of branchwise if operands should equal branchwise min/max under the same condition.
law: (= (fuzz-add (fuzz-min (if {cond} {a} {b}) (if {cond} {c} {d})) (fuzz-max (if {cond} {a} {b}) (if {cond} {c} {d}))) (if {cond} (fuzz-add {a} {c}) (fuzz-add {b} {d})))
