name: complex_combo_nested_do_if_comparison_roundtrip
section: combo
tier: stable
kind: law
features: arithmetic, combo, do, equality, if, phi, predicate, set
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.predicate_dispatch, codegen.runtime_call, codegen.sequence, infer.arithmetic, infer.equality, infer.if_phi, infer.type_predicate, reader.ast_do, reader.ast_if, runtime.set
uses-atoms: atom.control.do, atom.control.if, atom.core.equality, atom.infer.predicate
related-properties: signal_v13_atom_do_last_value, signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates
signal: medium
corpus-role: semantic-law
args: setup:Int cond:Bool a:Int b:Int
type: Bool
expect: True
description: Do sequencing inside a Bool identity and if condition should preserve comparison branch behavior.
law: (= (if (fuzz-bool-id? (do {setup} {cond})) (fuzz-lt? {a} {b}) (fuzz-gte? {a} {b})) (if {cond} (fuzz-lt? {a} {b}) (fuzz-gte? {a} {b})))
