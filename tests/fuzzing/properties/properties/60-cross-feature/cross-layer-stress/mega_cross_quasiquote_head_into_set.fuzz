name: mega_cross_quasiquote_head_into_set
section: codegen-cross-layer-stress
tier: stable
kind: law
features: arithmetic, codegen, predicate, quasiquote, quote, set, unquote
compiler-path: codegen.arithmetic_dispatch, codegen.predicate_dispatch, codegen.quote, codegen.runtime_call, desugar.quasiquote, infer.arithmetic, infer.type_predicate, reader.quasiquote, reader.quote, reader.unquote, runtime.set
uses-atoms: atom.codegen.dispatch, atom.infer.predicate, atom.quote.quote
signal: medium
corpus-role: semantic-law
args: a:Int
type: Bool
expect: True
description: quasiquote unquote result must be usable as set key.
law: (contains? (set {a}) (head (quasiquote ((unquote {a}) tail))))
