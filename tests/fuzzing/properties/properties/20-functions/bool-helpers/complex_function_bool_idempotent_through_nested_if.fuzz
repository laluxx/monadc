name: complex_function_bool_idempotent_through_nested_if
section: function-bool
tier: stable
kind: law
features: arithmetic, equality, function, if, phi, predicate
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.predicate_dispatch, infer.arithmetic, infer.equality, infer.if_phi, infer.type_predicate, reader.ast_if
