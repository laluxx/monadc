name: complex_arith_helper_mul_one_roundtrip_through_id
section: arithmetic-function
tier: stable
kind: law
features: arithmetic, equality
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, infer.arithmetic, infer.equality
uses-atoms: atom.core.equality
related-properties: signal_v13_atom_equality_reflexive
signal: medium
corpus-role: semantic-law
args: a:Int b:Int
type: Bool
expect: True
description: A value multiplied by a computed one and passed through identity should preserve the original.
law: (= (fuzz-id-int (fuzz-mul {a} (fuzz-add 1 (fuzz-sub {b} {b})))) {a})
