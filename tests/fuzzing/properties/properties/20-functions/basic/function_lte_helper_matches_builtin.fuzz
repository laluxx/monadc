name: function_lte_helper_matches_builtin
section: function
tier: stable
kind: law
features: arithmetic, comparison, equality, function, predicate
compiler-path: codegen.arithmetic_dispatch, codegen.comparison_dispatch, codegen.equality_dispatch, codegen.predicate_dispatch, infer.arithmetic, infer.comparison, infer.equality, infer.type_predicate
