name: function_int_id_preserves_multiplication
section: function
tier: stable
kind: law
features: arithmetic, equality, function
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, infer.arithmetic, infer.equality
uses-atoms: atom.core.equality
related-properties: signal_v13_atom_equality_reflexive
signal: medium
corpus-role: semantic-law
args: a:Int b:Int
type: Bool
expect: True
description: The typed Int identity helper must preserve a multiplication expression and its operands.
law: (= (fuzz-id-int (fuzz-mul {a} {b})) (fuzz-mul (fuzz-id-int {a}) (fuzz-id-int {b})))
