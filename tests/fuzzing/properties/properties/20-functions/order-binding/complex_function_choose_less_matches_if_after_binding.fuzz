name: complex_function_choose_less_matches_if_after_binding
section: function-order-binding
tier: stable
kind: law
features: arithmetic, array, array-index, env, equality, function, if, logic, phi, predicate, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.logic_dispatch, codegen.predicate_dispatch, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, infer.logic, infer.type_predicate, reader.array_literal, reader.ast_if
uses-atoms: atom.binding.with, atom.control.if, atom.core.equality, atom.infer.predicate, atom.logic.and, atom.logic.not, atom.logic.or, atom.runtime.array
related-properties: signal_v13_atom_array_index_valid, signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates, signal_v13_atom_with_substitution
signal: medium
corpus-role: semantic-law
args: a:Int b:Int fallback:Int
type: Bool
expect: True
description: The choose-less helper must match its if definition even when operands are bound first.
law: (= (with [x {a} y {b} z {fallback}] (fuzz-choose-less x y z)) (with [x {a} y {b} z {fallback}] (if (fuzz-lt? x y) x z)))
