name: complex_function_choose_less_with_max_fallback
section: function-order
tier: stable
kind: law
features: arithmetic, env, equality, function, if, logic, phi, predicate, with
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.logic_dispatch, codegen.predicate_dispatch, codegen.with_binding, infer.arithmetic, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, infer.logic, infer.type_predicate, reader.ast_if
uses-atoms: atom.binding.with, atom.control.if, atom.core.equality, atom.infer.predicate, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates, signal_v13_atom_with_substitution
signal: medium
corpus-role: semantic-law
args: a:Int b:Int
type: Bool
expect: True
description: Choosing a when it is less than b and otherwise max(a,b) must always produce min/max-selected value equal to min when ordered or max otherwise.
law: (= (fuzz-choose-less {a} {b} (fuzz-max {a} {b})) (if (fuzz-lt? {a} {b}) {a} (fuzz-max {a} {b})))
