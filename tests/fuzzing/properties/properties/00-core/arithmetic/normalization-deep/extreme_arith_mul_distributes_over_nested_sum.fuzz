name: extreme_arith_mul_distributes_over_nested_sum
section: arithmetic-normalization-deep
tier: stable
kind: law
features: arithmetic, equality, logic
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, infer.arithmetic, infer.equality, infer.logic
uses-atoms: atom.core.equality, atom.core.multiply, atom.core.plus, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_multiply_associative, signal_v13_atom_multiply_commutative, signal_v13_atom_multiply_identity_one, signal_v13_atom_plus_associative, signal_v13_atom_plus_commutative, signal_v13_atom_plus_identity_zero
signal: medium
corpus-role: semantic-law
args: k:Int a:Int b:Int c:Int
type: Bool
expect: True
description: Deep arithmetic normalization must preserve integer semantics across direct codegen and helper calls.
law: (= (* {k} (+ {a} (+ {b} {c}))) (+ (* {k} {a}) (+ (* {k} {b}) (* {k} {c}))))
