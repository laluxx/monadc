name: int_add_same_offset_preserves_equality
section: arithmetic
tier: stable
kind: law
features: arithmetic, equality, logic, predicate, set
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, codegen.predicate_dispatch, codegen.runtime_call, infer.arithmetic, infer.equality, infer.logic, infer.type_predicate, runtime.set
uses-atoms: atom.core.equality, atom.infer.predicate, atom.logic.and, atom.logic.not, atom.logic.or
