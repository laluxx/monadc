name: max_with_upper_operand_after_offset
section: order
tier: stable
kind: law
features: arithmetic, env, equality, if, logic, order, phi, predicate, set, with
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.logic_dispatch, codegen.predicate_dispatch, codegen.runtime_call, codegen.with_binding, infer.arithmetic, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, infer.logic, infer.type_predicate, reader.ast_if, runtime.set
uses-atoms: atom.binding.with, atom.control.if, atom.core.equality, atom.infer.predicate, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_if_same_branch_eliminates, signal_v13_atom_with_substitution
signal: medium
corpus-role: semantic-law
args: a:Int b:Int c:Int
type: Bool
expect: True
description: If b is above a, adding the same offset must make max choose the offset b side.
law: (if (fuzz-lte? {a} {b}) (= (fuzz-max (fuzz-add {a} {c}) (fuzz-add {b} {c})) (fuzz-add {b} {c})) True)
