name: extreme_lattice_clamp_idempotent_ordered
section: lattice-clamp-deep
args: x:Int lo:Int hi:Int
type: Bool
expect: True
description: Min/max lattice and clamp laws must hold through helper-based branch implementations.
law: (if (<= {lo} {hi}) (= (fuzz-min {hi} (fuzz-max {lo} (fuzz-min {hi} (fuzz-max {lo} {x})))) (fuzz-min {hi} (fuzz-max {lo} {x}))) True)
