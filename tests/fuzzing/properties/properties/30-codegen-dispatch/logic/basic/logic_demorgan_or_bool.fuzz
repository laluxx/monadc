name: logic_demorgan_or_bool
section: logic
tier: stable
kind: law
features: arithmetic, equality, logic
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, infer.arithmetic, infer.equality, infer.logic
uses-atoms: atom.core.equality, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_v13_atom_equality_reflexive
signal: medium
corpus-role: semantic-law
args: p:Bool q:Bool
type: Bool
expect: True
description: De Morgan over or/and/not must hold for generated Bool expressions.
law: (= (not (or {p} {q})) (and (not {p}) (not {q})))
