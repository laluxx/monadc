name: mega_compare_variadic_lt_triple_pairwise
section: codegen-compare-variadic
tier: stable
kind: law
features: arithmetic, codegen, comparison, equality, logic
compiler-path: codegen.arithmetic_dispatch, codegen.comparison_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, infer.arithmetic, infer.comparison, infer.equality, infer.logic
uses-atoms: atom.codegen.dispatch, atom.core.equality, atom.core.order.lt, atom.logic.and, atom.logic.not, atom.logic.or
