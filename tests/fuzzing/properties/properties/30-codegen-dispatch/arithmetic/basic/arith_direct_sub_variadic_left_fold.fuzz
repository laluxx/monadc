name: arith_direct_sub_variadic_left_fold
section: arithmetic-dispatch
tier: stable
kind: law
features: arithmetic, equality
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, infer.arithmetic, infer.equality
uses-atoms: atom.codegen.dispatch, atom.core.equality, atom.core.minus
