name: arith_direct_mul_distributes_over_variadic_add
section: arithmetic-dispatch
tier: stable
kind: law
features: arithmetic, equality
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, infer.arithmetic, infer.equality
uses-atoms: atom.codegen.dispatch, atom.core.equality, atom.core.multiply, atom.core.plus
related-properties: signal_v13_atom_equality_reflexive, signal_v13_atom_multiply_associative, signal_v13_atom_multiply_commutative, signal_v13_atom_multiply_identity_one, signal_v13_atom_plus_associative, signal_v13_atom_plus_commutative, signal_v13_atom_plus_identity_zero
signal: medium
corpus-role: semantic-law
args: a:Int b:Int c:Int d:Int
type: Bool
expect: True
description: Direct * must distribute over a variadic + expression.
law: (= (* {a} (+ {b} {c} {d})) (+ (* {a} {b}) (* {a} {c}) (* {a} {d})))
