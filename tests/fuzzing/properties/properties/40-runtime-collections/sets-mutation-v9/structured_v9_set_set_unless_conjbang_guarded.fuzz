name: structured_v9_set_set_unless_conjbang_guarded
section: collections-set-v9
args: p:Bool a:Int
type: Bool
expect: True
description: Stress persistent and mutable set operations, membership, duplicate handling, and branch guarded mutation.
law: (= (with [s (set)] (do (unless {p} (conj! s {a})) (contains? s {a}))) (not {p}))
