name: structured_v9_set_set_if_conj_or_disj_contains
section: collections-set-v9
args: p:Bool a:Int
type: Bool
expect: True
description: Stress persistent and mutable set operations, membership, duplicate handling, and branch guarded mutation.
law: (= (with [s (set {a})] (do (if {p} (disj! s {a}) (conj! s {a})) (contains? s {a}))) (not {p}))
