name: complex_function_min_max_helpers_are_order_duals
section: function-order
tier: stable
kind: law
features: arithmetic, equality, function, logic
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, infer.arithmetic, infer.equality, infer.logic
signal: medium
corpus-role: semantic-law
uses-atoms: atom.core.equality, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_atom_equality_reflexive
args: a:Int b:Int
type: Bool
expect: True
description: Min and max helpers should swap when argument order is swapped.
law: (= (fuzz-add (fuzz-min {a} {b}) (fuzz-max {b} {a})) (fuzz-add (fuzz-min {b} {a}) (fuzz-max {a} {b})))
