name: extreme_arith_helper_direct_mul_mix
section: arithmetic-normalization-deep
tier: stable
kind: law
features: arithmetic, equality, logic
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, infer.arithmetic, infer.equality, infer.logic
signal: medium
corpus-role: semantic-law
uses-atoms: atom.core.equality, atom.core.multiply, atom.core.plus, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_atom_equality_reflexive, signal_atom_multiply_associative, signal_atom_multiply_commutative, signal_atom_multiply_identity_one, signal_atom_plus_associative, signal_atom_plus_commutative, signal_atom_plus_identity_zero
args: a:Int b:Int c:Int
