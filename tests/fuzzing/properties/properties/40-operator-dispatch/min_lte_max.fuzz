name: min_lte_max
section: order
tier: stable
kind: law
features: arithmetic, logic, order, predicate
compiler-path: codegen.arithmetic_dispatch, codegen.logic_dispatch, codegen.predicate_dispatch, infer.arithmetic, infer.logic, infer.type_predicate
signal: medium
corpus-role: semantic-law
uses-atoms: atom.infer.predicate, atom.logic.and, atom.logic.not, atom.logic.or
args: a:Int b:Int
type: Bool
expect: True
description: The minimum of two generated values must be less than or equal to their maximum.
law: (fuzz-lte? (fuzz-min {a} {b}) (fuzz-max {a} {b}))
