name: arith_div_mul_roundtrip_constant
section: arithmetic-dispatch
tier: stable
kind: law
features: arithmetic, equality
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, infer.arithmetic, infer.equality
signal: medium
corpus-role: semantic-law
uses-atoms: atom.codegen.dispatch, atom.core.equality, atom.core.multiply
related-properties: signal_atom_equality_reflexive, signal_atom_multiply_associative, signal_atom_multiply_commutative, signal_atom_multiply_identity_one
args: a:Int
type: Bool
expect: True
description: Division by a nonzero constant must roundtrip a prior multiplication by a multiple.
law: (= (/ (* {a} 12) 3) (* {a} 4))
