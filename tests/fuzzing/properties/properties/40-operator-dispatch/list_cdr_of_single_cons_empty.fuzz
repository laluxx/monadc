name: list_cdr_of_single_cons_empty
section: collections
tier: stable
kind: law
features: arithmetic, collections, list, predicate
compiler-path: codegen.arithmetic_dispatch, codegen.predicate_dispatch, codegen.runtime_call, infer.arithmetic, infer.type_predicate, runtime.list
