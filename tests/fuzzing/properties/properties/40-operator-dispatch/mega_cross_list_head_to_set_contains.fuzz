name: mega_cross_list_head_to_set_contains
section: codegen-runtime-collections
tier: stable
kind: law
features: arithmetic, codegen, list, predicate, set
compiler-path: codegen.arithmetic_dispatch, codegen.predicate_dispatch, codegen.runtime_call, infer.arithmetic, infer.type_predicate, runtime.list, runtime.set
signal: medium
corpus-role: semantic-law
uses-atoms: atom.codegen.dispatch, atom.infer.predicate
args: a:Int
type: Bool
expect: True
description: generated value through list head must be usable as set key.
law: (contains? (set {a}) (head (cons {a} (list))))
