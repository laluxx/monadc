name: function_int_id_preserves_addition
section: function
tier: stable
kind: law
features: arithmetic, equality, function
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, infer.arithmetic, infer.equality
signal: medium
corpus-role: semantic-law
uses-atoms: atom.core.equality
related-properties: signal_atom_equality_reflexive
args: a:Int b:Int
type: Bool
expect: True
description: The typed Int identity helper must preserve an addition expression and its operands.
law: (= (fuzz-id-int (fuzz-add {a} {b})) (fuzz-add (fuzz-id-int {a}) (fuzz-id-int {b})))
