name: complex_arith_binomial_square_expansion
section: arithmetic-normalization
tier: stable
kind: law
features: arithmetic, equality, logic
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, infer.arithmetic, infer.equality, infer.logic
signal: medium
corpus-role: semantic-law
uses-atoms: atom.core.equality, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_atom_equality_reflexive
args: a:Int b:Int
type: Bool
expect: True
description: The square of a sum must match the expanded binomial form.
law: (= (fuzz-mul (fuzz-add {a} {b}) (fuzz-add {a} {b})) (fuzz-add (fuzz-add (fuzz-mul {a} {a}) (fuzz-mul (fuzz-mul 2 {a}) {b})) (fuzz-mul {b} {b})))
