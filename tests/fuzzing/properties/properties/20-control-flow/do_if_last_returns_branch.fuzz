name: do_if_last_returns_branch
section: control
tier: stable
kind: law
features: arithmetic, control, do, equality, if, phi, set
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.runtime_call, codegen.sequence, infer.arithmetic, infer.equality, infer.if_phi, reader.ast_do, reader.ast_if, runtime.set
signal: medium
corpus-role: semantic-law
uses-atoms: atom.control.do, atom.control.if, atom.core.equality
