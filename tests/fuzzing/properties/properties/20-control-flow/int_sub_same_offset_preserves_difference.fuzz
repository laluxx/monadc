name: int_sub_same_offset_preserves_difference
section: arithmetic
tier: stable
kind: law
features: arithmetic, equality, if, logic, phi, set
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.logic_dispatch, codegen.runtime_call, infer.arithmetic, infer.equality, infer.if_phi, infer.logic, reader.ast_if, runtime.set
signal: medium
corpus-role: semantic-law
