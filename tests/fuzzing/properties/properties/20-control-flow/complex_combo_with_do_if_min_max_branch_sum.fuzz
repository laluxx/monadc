name: complex_combo_with_do_if_min_max_branch_sum
section: combo
tier: stable
kind: law
features: arithmetic, array, array-index, combo, do, env, equality, if, phi, set, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.runtime_call, codegen.sequence, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, reader.array_literal, reader.ast_do, reader.ast_if, runtime.set
signal: medium
corpus-role: semantic-law
uses-atoms: atom.binding.with, atom.control.do, atom.control.if, atom.core.equality, atom.runtime.array
related-properties: signal_atom_array_index_valid, signal_atom_do_last_value, signal_atom_equality_reflexive, signal_atom_if_same_branch_eliminates, signal_atom_with_substitution
args: cond:Bool a:Int b:Int setup:Int
type: Bool
expect: True
description: Combining with, do, if, min, and max should preserve the selected branch sum.
law: (= (with [lo (fuzz-min {a} {b}) hi (fuzz-max {a} {b})] (do {setup} (if {cond} (fuzz-add lo hi) (fuzz-sub hi lo)))) (if {cond} (fuzz-add {a} {b}) (fuzz-sub (fuzz-max {a} {b}) (fuzz-min {a} {b}))))
