name: complex_arith_if_selected_one_identity_multiplication
section: arithmetic-if
tier: stable
kind: law
features: arithmetic, equality, if, phi
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, infer.arithmetic, infer.equality, infer.if_phi, reader.ast_if
signal: medium
corpus-role: semantic-law
uses-atoms: atom.control.if, atom.core.equality
related-properties: signal_atom_equality_reflexive, signal_atom_if_same_branch_eliminates
args: cond:Bool a:Int b:Int
type: Bool
expect: True
description: Multiplication by an if-selected one should preserve the other operand.
law: (= (fuzz-mul {a} (if {cond} 1 (fuzz-add (fuzz-sub {b} {b}) 1))) {a})
