name: with_nested_shadowing
section: binding
tier: stable
kind: law
features: arithmetic, array, array-index, binding, do, env, equality, set, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.equality_dispatch, codegen.local_load, codegen.runtime_call, codegen.sequence, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, reader.array_literal, reader.ast_do, runtime.set
signal: medium
corpus-role: semantic-law
uses-atoms: atom.binding.with, atom.core.equality, atom.runtime.array
related-properties: signal_atom_array_index_valid, signal_atom_equality_reflexive, signal_atom_with_substitution
args: outer:Int inner:Int offset:Int
type: Bool
expect: True
description: An inner with binding must shadow an outer binding of the same name.
law: (= (with [x {outer}] (with [x {inner}] (fuzz-add x {offset}))) (fuzz-add {inner} {offset}))
