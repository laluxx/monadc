name: complex_if_distributes_over_less_than_same_condition
section: control-if
tier: stable
kind: law
features: arithmetic, control, equality, if, phi, predicate
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.predicate_dispatch, infer.arithmetic, infer.equality, infer.if_phi, infer.type_predicate, reader.ast_if
signal: medium
corpus-role: semantic-law
uses-atoms: atom.control.if, atom.core.equality, atom.infer.predicate
related-properties: signal_atom_equality_reflexive, signal_atom_if_same_branch_eliminates
args: cond:Bool a:Int b:Int c:Int d:Int
type: Bool
expect: True
description: Less-than between if expressions sharing a condition must be equivalent to branchwise less-than.
law: (= (fuzz-lt? (if {cond} {a} {b}) (if {cond} {c} {d})) (if {cond} (fuzz-lt? {a} {c}) (fuzz-lt? {b} {d})))
