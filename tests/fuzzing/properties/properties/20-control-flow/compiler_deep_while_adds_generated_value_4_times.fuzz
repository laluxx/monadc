name: compiler_deep_while_adds_generated_value_4_times
section: control-loop-mutation-current
tier: stable
kind: law
features: arithmetic, array, array-index, begin, comparison, control, do, env, equality, mutation, set, set!, while, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.comparison_dispatch, codegen.equality_dispatch, codegen.local_load, codegen.runtime_call, codegen.sequence, codegen.set_bang, codegen.store, codegen.while_loop, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.comparison, infer.env_child, infer.env_lookup, infer.equality, infer.loop, infer.mutation, reader.array_literal, reader.ast_begin, reader.ast_do, runtime.set
