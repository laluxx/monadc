name: complex_lattice_no_value_below_min_and_above_max
section: lattice-order
tier: stable
kind: law
features: arithmetic, if, lattice, logic, phi, predicate
compiler-path: codegen.arithmetic_dispatch, codegen.branch_phi, codegen.if_phi, codegen.logic_dispatch, codegen.predicate_dispatch, infer.arithmetic, infer.if_phi, infer.logic, infer.type_predicate, reader.ast_if
signal: medium
corpus-role: semantic-law
uses-atoms: atom.control.if, atom.infer.predicate, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_atom_if_same_branch_eliminates
args: a:Int b:Int x:Int
type: Bool
expect: True
description: A value below both operands is below min; a value above both operands is above max.
law: (if (fuzz-lte? {x} {a}) (if (fuzz-lte? {x} {b}) (fuzz-lte? {x} (fuzz-min {a} {b})) True) True)
