name: complex_with_shadowed_int_inside_else_branch
section: binding-if
tier: stable
kind: law
features: arithmetic, array, array-index, binding, do, env, equality, if, phi, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.sequence, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, reader.array_literal, reader.ast_do, reader.ast_if
