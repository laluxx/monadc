name: with_nested_outer_visible_after_inner
section: binding
tier: stable
kind: law
features: arithmetic, array, array-index, binding, env, equality, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.equality_dispatch, codegen.local_load, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, reader.array_literal
signal: medium
corpus-role: semantic-law
uses-atoms: atom.binding.with, atom.core.equality, atom.runtime.array
related-properties: signal_atom_array_index_valid, signal_atom_equality_reflexive, signal_atom_with_substitution
args: outer:Int inner:Int offset:Int
type: Bool
expect: True
description: After an inner shadowing binding ends, the outer binding must remain visible in the surrounding body.
law: (= (with [x {outer}] (fuzz-add (with [x {inner}] x) x)) (fuzz-add {inner} {outer}))
