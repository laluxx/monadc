name: extreme_with_bound_condition_controls_branch
section: binding-scope-deep
tier: stable
kind: law
features: arithmetic, array, array-index, binding, env, equality, if, phi, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, reader.array_literal, reader.ast_if
