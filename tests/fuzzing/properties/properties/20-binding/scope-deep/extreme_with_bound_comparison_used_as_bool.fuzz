name: extreme_with_bound_comparison_used_as_bool
section: binding-scope-deep
tier: stable
kind: law
features: arithmetic, array, array-index, binding, comparison, env, equality, if, phi, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.branch_phi, codegen.comparison_dispatch, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.comparison, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, reader.array_literal, reader.ast_if
uses-atoms: atom.binding.with, atom.control.if, atom.core.equality, atom.core.order.lt, atom.runtime.array
