name: with_binding_in_comparison
section: binding
tier: stable
kind: law
features: arithmetic, array, array-index, binding, env, equality, predicate, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.equality_dispatch, codegen.local_load, codegen.predicate_dispatch, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, infer.type_predicate, reader.array_literal
uses-atoms: atom.binding.with, atom.core.equality, atom.infer.predicate, atom.runtime.array
related-properties: signal_v13_atom_array_index_valid, signal_v13_atom_equality_reflexive, signal_v13_atom_with_substitution
signal: medium
corpus-role: semantic-law
args: a:Int b:Int
type: Bool
expect: True
description: With-bound Int values must be usable in comparison helpers.
law: (= (with [x {a} y {b}] (fuzz-lt? x y)) (fuzz-lt? {a} {b}))
