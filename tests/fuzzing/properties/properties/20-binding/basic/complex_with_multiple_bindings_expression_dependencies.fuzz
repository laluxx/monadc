name: complex_with_multiple_bindings_expression_dependencies
section: binding
tier: stable
kind: law
features: arithmetic, array, array-index, binding, env, equality, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.equality_dispatch, codegen.local_load, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, reader.array_literal
uses-atoms: atom.binding.with, atom.core.equality, atom.runtime.array
related-properties: signal_v13_atom_array_index_valid, signal_v13_atom_equality_reflexive, signal_v13_atom_with_substitution
signal: medium
corpus-role: semantic-law
args: a:Int b:Int c:Int
type: Bool
expect: True
description: Later with bindings may depend on earlier bindings and should preserve the expected expanded expression.
law: (= (with [x {a} y (fuzz-add x {b}) z (fuzz-sub y {c})] z) (fuzz-sub (fuzz-add {a} {b}) {c}))
