name: complex_with_int_binding_used_in_both_if_branches
section: binding-if
tier: stable
kind: law
features: arithmetic, array, array-index, binding, env, equality, if, phi, set, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.branch_phi, codegen.equality_dispatch, codegen.if_phi, codegen.local_load, codegen.runtime_call, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, infer.if_phi, reader.array_literal, reader.ast_if, runtime.set
