name: mega_bind_shadow_tower_9_outer_preserved
section: codegen-binding-env
args: a:Int b:Int
type: Bool
expect: True
description: 9 nested shadowing scopes must not overwrite the outer binding.
law: (= (with [x {a}] (do (with [x (+ {b} 0)] x) (with [x (+ {b} 1)] x) (with [x (+ {b} 2)] x) (with [x (+ {b} 3)] x) (with [x (+ {b} 4)] x) (with [x (+ {b} 5)] x) (with [x (+ {b} 6)] x) (with [x (+ {b} 7)] x) (with [x (+ {b} 8)] x) x)) {a})
