name: mega_bind_shadow_tower_5_outer_preserved
section: codegen-binding-env
tier: stable
kind: law
features: arithmetic, array, array-index, codegen, do, env, equality, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.equality_dispatch, codegen.local_load, codegen.sequence, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, reader.array_literal, reader.ast_do
uses-atoms: atom.binding.with, atom.codegen.dispatch, atom.control.do, atom.core.equality, atom.core.plus, atom.runtime.array
related-properties: signal_v13_atom_array_index_valid, signal_v13_atom_do_last_value, signal_v13_atom_equality_reflexive, signal_v13_atom_plus_associative, signal_v13_atom_plus_commutative, signal_v13_atom_plus_identity_zero, signal_v13_atom_with_substitution
signal: medium
corpus-role: semantic-law
args: a:Int b:Int
type: Bool
expect: True
description: 5 nested shadowing scopes must not overwrite the outer binding.
law: (= (with [x {a}] (do (with [x (+ {b} 0)] x) (with [x (+ {b} 1)] x) (with [x (+ {b} 2)] x) (with [x (+ {b} 3)] x) (with [x (+ {b} 4)] x) x)) {a})
