name: mega_bind_shadow_tower_6_outer_preserved
section: codegen-binding-env
args: a:Int b:Int
type: Bool
expect: True
description: 6 nested shadowing scopes must not overwrite the outer binding.
law: (= (with [x {a}] (do (with [x (+ {b} 0)] x) (with [x (+ {b} 1)] x) (with [x (+ {b} 2)] x) (with [x (+ {b} 3)] x) (with [x (+ {b} 4)] x) (with [x (+ {b} 5)] x) x)) {a})
