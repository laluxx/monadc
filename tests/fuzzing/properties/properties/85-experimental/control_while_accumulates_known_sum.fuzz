name: control_while_accumulates_known_sum
section: control-binding
tier: experimental
kind: law
features: arithmetic, array, array-index, begin, comparison, control, env, equality, mutation, set, set!, while, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.comparison_dispatch, codegen.equality_dispatch, codegen.local_load, codegen.runtime_call, codegen.sequence, codegen.set_bang, codegen.store, codegen.while_loop, codegen.with_binding, infer.arithmetic, infer.array, infer.callable_array, infer.comparison, infer.env_child, infer.env_lookup, infer.equality, infer.loop, infer.mutation, reader.array_literal, reader.ast_begin, runtime.set
signal: low
