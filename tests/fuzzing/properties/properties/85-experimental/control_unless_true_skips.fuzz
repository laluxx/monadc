name: control_unless_true_skips
section: control-binding
tier: experimental
kind: law
features: arithmetic, array, array-index, begin, control, env, equality, mutation, set, set!, unless, with
compiler-path: codegen.arithmetic_dispatch, codegen.array_index, codegen.array_literal, codegen.equality_dispatch, codegen.if_void, codegen.local_load, codegen.runtime_call, codegen.sequence, codegen.set_bang, codegen.store, codegen.with_binding, desugar.unless, infer.arithmetic, infer.array, infer.callable_array, infer.env_child, infer.env_lookup, infer.equality, infer.mutation, reader.array_literal, reader.ast_begin, runtime.set
signal: low
