corpus-role: semantic-law
args: a:Int b:Int c:Int
type: Bool
expect: True
description: Variadic add must preserve operand values when do/begin appear inside operands.
law: (= (+ (do {c} {a}) (begin {a} {b}) {c}) (+ {a} {b} {c}))
