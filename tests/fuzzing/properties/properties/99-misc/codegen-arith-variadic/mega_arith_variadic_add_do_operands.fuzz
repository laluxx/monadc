name: mega_arith_variadic_add_do_operands
section: codegen-arith-variadic
tier: stable
kind: law
features: arithmetic, begin, codegen, do, equality, logic
compiler-path: codegen.arithmetic_dispatch, codegen.equality_dispatch, codegen.logic_dispatch, codegen.sequence, infer.arithmetic, infer.equality, infer.logic, reader.ast_begin, reader.ast_do
uses-atoms: atom.codegen.dispatch, atom.control.begin, atom.control.do, atom.core.equality, atom.core.plus, atom.logic.and, atom.logic.not, atom.logic.or
related-properties: signal_v13_atom_do_last_value, signal_v13_atom_equality_reflexive, signal_v13_atom_plus_associative, signal_v13_atom_plus_commutative, signal_v13_atom_plus_identity_zero
