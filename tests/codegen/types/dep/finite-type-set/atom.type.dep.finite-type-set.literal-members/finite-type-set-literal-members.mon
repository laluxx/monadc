;; TEST-ATOM-LEAF: atom.type.dep.finite-type-set.literal-members
;; TEST-CLI-TARGET: codegen types dep finite-type-sets

(module Main)
(type Die {1 2 3 4 5 6})
(type Answer {"yes" "no"})
(type Letter {'a' 'b'})
(type Bit {Low High})
(define (pip-name [pip : Die] -> String)
  1 -> "one"
  2 -> "two"
  3 -> "three"
  4 -> "four"
  5 -> "five"
  6 -> "six")
(show (pip-name 4))
(define (answer-code [answer : Answer] -> Int)
  "yes" -> 1
  "no"  -> 0)
(define (letter-name [letter : Letter] -> String)
  'a' -> "a"
  'b' -> "b")
(show (answer-code "no"))
(show (letter-name 'b'))
(define (xor-bit [left : Bit] [right : Bit] -> Bit)
  Low  Low  -> Low
  Low  High -> High
  High Low  -> High
  High High -> Low)
(show (xor-bit Low High))
