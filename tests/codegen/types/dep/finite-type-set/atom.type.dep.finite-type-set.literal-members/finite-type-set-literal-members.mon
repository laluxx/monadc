;; TEST-PURPOSE: Finite sets contain arbitrary decidable singleton literals, not only symbols.
;; TEST-EXPECT: compile, run
;; TEST-STDOUT-FILE: finite-type-set-literal-members.stdout
;; TEST-CODEGEN-PATH: types.dep.finite-type-set.literal-members
;; TEST-MENU: types/dep/finite-type-set/atom.type.dep.finite-type-set.literal-members
