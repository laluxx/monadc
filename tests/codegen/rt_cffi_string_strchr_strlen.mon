;; TEST-ID: tests.codegen.rt-cffi-string-strchr-strlen
;; TEST-SECTION: cffi
;; TEST-CONTEXT: monadc.context.language.cffi-runtime
;; TEST-PURPOSE: Runtime C FFI composes a C string-returning function with strlen.
;; TEST-ATOM: (strlen (strchr "abc" 98)) prints 2.
;; TEST-EXPECT: compile, run

(module Main)
(include "string.h")
(show (strlen (strchr "abc" 98)))
