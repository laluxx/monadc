;; TEST-ID: tests.codegen.rt-path-literal-array-rejected
;; TEST-CONTEXT: monadc.context.reader.path-literals, monadc.context.language.path-literals, monadc.context.tests.expected-failures
;; TEST-PURPOSE: Verify Unix path literals nested inside arrays are rejected before they become runtime values.
