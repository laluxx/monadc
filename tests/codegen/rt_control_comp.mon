;; TEST-ID: tests.codegen.rt-control-comp
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Compact control flow check: if string branches, begin, and unless body execution.
;; TEST-ATOM: (if True "yes" "no") = "yes", (if False "yes" "no") = "no", (begin 1 2 3) = 3, (unless False (show "executed")) prints executed.
;; TEST-EXPECT: compile, run
(module Main)
(show (if True "yes" "no"))
(show (if False "yes" "no"))
(show (begin 1 2 3))
(unless False (show "executed"))
