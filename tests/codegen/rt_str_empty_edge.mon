;; TEST-ID: tests.codegen.rt-str-empty-edge
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Edge cases for string predicates with empty strings
;; TEST-ATOM: (starts-with? "" "") = True, (ends-with? "" "") = True, (contains? "" "") = True, (starts-with? "a" "") = True, (ends-with? "a" "") = True, (contains? "a" "") = True
;; TEST-EXPECT: compile, run
(module Main)
(show (starts-with? "" ""))
(show (ends-with? "" ""))
(show (contains? "" ""))
(show (starts-with? "a" ""))
(show (ends-with? "a" ""))
(show (contains? "a" ""))
