;; TEST-ID: tests.codegen.rt-cffi-math-fabs
;; TEST-SECTION: cffi
;; TEST-CONTEXT: monadc.context.language.cffi-runtime
;; TEST-PURPOSE: Runtime C FFI calls a double-returning absolute value function.
