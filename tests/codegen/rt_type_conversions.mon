;; TEST-ID: tests.codegen.rt-type-conversions
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Type conversion functions Int, Float, Hex, Oct, Bin, Char.
;; TEST-ATOM: (Float 42) = 42.0, (Int 3.14) = 3, (Hex 255) = 0xFF,
;;           (Oct 255) = 0o377, (Bin 7) = 0b111, (Char 65) = #\A
;; TEST-EXPECT: compile, run
(module Main)
(show (Float 42))
(show (Int 3.14))
(show (Hex 255))
(show (Oct 255))
(show (Bin 7))
(show (Char 65))
