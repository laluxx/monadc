;; TEST-CATEGORY: codegen
;; TEST-KIND: runtime
;; TEST-FEATURES: wisp, define, typed-signature, pattern-clause, guard, higher-order, collection, generic
;; TEST-EXPECT: pass
;; TEST-STDOUT-FILE: rt_wisp_old_core_takewhile_after_take_drop.stdout
;; TEST-WORKFLOW: core-prelude
;; TEST-ATOM: old-core style takeWhile compiles after take/drop definitions in the same module.
;; TEST-CONTEXT: monadc.context.wisp.old-core-prelude-compat

module Main

define take :: Int -> [a] -> [a]
  _ []            -> []
  n [x|xs]
      | n > 0     -> (x ++ (take (n - 1) xs))
      | otherwise -> []

define drop :: Int -> [a] -> [a]
  _ []            -> []
  n [x|xs]
      | n > 0     -> (drop (n - 1) xs)
      | otherwise -> (x ++ xs)

define positive? :: Int -> Bool
  n -> n > 0

define takeWhile :: (a -> Bool) -> [a] -> [a]
  _ []            -> []
  p [x|xs]
      | p x       -> (x ++ (takeWhile p xs))
      | otherwise -> []

show (takeWhile positive? [7 8 -1 9])
show (takeWhile positive? [-1 9])
