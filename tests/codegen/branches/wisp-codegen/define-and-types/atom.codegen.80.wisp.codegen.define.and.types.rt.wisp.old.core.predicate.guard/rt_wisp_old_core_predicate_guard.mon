;; TEST-CLI-TARGET: codegen branches wisp-codegen define-and-types
module Main

define positive? :: Int -> Bool
  n -> n > 0

define first-matching :: (Int -> Bool) -> Arr -> Int
  _ []            -> 0
  p [x|xs]
      | p x       -> x
      | otherwise -> 0

show (first-matching positive? [7 8])
show (first-matching positive? [-7 8])
