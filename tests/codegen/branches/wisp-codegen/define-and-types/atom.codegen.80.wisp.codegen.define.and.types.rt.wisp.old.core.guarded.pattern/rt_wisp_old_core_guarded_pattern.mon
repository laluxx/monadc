;; TEST-CLI-TARGET: codegen branches wisp-codegen define-and-types
module Main

define first-when-positive :: Int -> Arr -> Int
  _ []            -> 0
  n [x|xs]
      | n > 0     -> x
      | otherwise -> 0

show (first-when-positive 1 [7 8])
show (first-when-positive 0 [7 8])
