module Main

define both :: (a -> Bool) -> (a -> Bool) -> (a -> Bool)
  f g -> (lambda (x) (and (f x) (g x)))

define positive? :: Int -> Bool
  n -> n > 0

define small? :: Int -> Bool
  n -> n < 4

(tests
  (assert-eq ((both positive? small?) 3) True "returned function accepts true case")
  (assert-eq ((both positive? small?) 5) False "returned function accepts false case")
)
