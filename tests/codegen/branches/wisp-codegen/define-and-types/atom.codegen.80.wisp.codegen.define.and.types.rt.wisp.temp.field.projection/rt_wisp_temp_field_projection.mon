;; TEST-ATOM-LEAF: atom.codegen.80.wisp.codegen.define.and.types.rt.wisp.temp.field.projection
;; TEST-CLI-TARGET: codegen branches wisp-codegen define-and-types
module Main

layout Pair
  [left :: Int]
  [right :: Int]

define make-pair :: Int -> Int -> Pair
  left right -> Pair left right

define pick-right :: _ -> Int
  _ -> (make-pair 20 22).right

show (pick-right 0)
