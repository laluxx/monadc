;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus, monadc.context.core-libs.coll
;; TEST-PURPOSE: A known higher-order function call keeps a function argument in prefix position.
;; TEST-ATOM: (apply2 + 4 5) compiles as a higher-order call, not an infix expression.
;; TEST-EXPECT: compile, run
;; TEST-COVERAGE: reader higher-order function argument parsing
;; TEST-USES-ATOM: atom.codegen.functions.higher.order.prefix.function.arg
;; TEST-MENU: branches/functions/higher-order-prefix-function-arg/atom.codegen.functions.higher.order.prefix.function.arg
