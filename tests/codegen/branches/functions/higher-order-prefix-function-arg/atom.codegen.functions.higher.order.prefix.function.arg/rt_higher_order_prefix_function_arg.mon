;; TEST-ATOM-LEAF: atom.codegen.functions.higher.order.prefix.function.arg
;; TEST-CLI-TARGET: codegen branches functions higher-order-prefix-function-arg

module Main

define apply2 :: (Int -> Int -> Int) -> Int -> Int -> Int
  f x y -> (f x y)

show (apply2 + 4 5)
