;; TEST-ATOM-LEAF: atom.codegen.functions.known.call.parenthesized.infix.arg
;; TEST-CLI-TARGET: codegen branches functions known-call-parenthesized-infix-arg

module Main

define step :: Int -> Int -> Int
  x y -> x + y

define use-step :: Int -> Int -> Int
  a b -> step b (a mod b)

show (use-step 14 5)
