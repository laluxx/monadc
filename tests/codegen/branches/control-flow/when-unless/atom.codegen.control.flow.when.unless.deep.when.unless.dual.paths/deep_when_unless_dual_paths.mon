;; TEST-CLI-TARGET: codegen branches control-flow when-unless
(module Main)
(define x 0)
(when True (set! x (+ x 1)))
(when False (set! x 99))
(show x)
(unless False (set! x (+ x 2)))
(unless True (set! x 99))
(show x)
