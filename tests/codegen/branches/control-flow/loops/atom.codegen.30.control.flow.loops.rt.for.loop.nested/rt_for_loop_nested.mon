;; TEST-ATOM-LEAF: atom.codegen.30.control.flow.loops.rt.for.loop.nested
;; TEST-CLI-TARGET: codegen branches control-flow loops
(module Main)
(define total 0)
(for [i 0 3]
  (for [j 0 2]
    (set! total (+ total (* i j)))))
(show total)
