;; TEST-CLI-TARGET: codegen branches control-flow loops
(module Main)
(define sum1 0)
(define sum2 0)
(define sum3 0)
(for [i 0 5] (set! sum1 (+ sum1 i)))
(for [i 1 4] (set! sum2 (+ sum2 i)))
(for [i 3 6] (set! sum3 (+ sum3 i)))
(show sum1)
(show sum2)
(show sum3)
