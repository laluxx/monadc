;; TEST-CLI-TARGET: codegen branches control-flow loops
(module Main)
(define (until [p : (a -> Bool)] [f : (a -> a)] [x : a] -> a)
  (if (p x) x (until p f (f x))))
(show (until (> 10) (+ 1) 5))
