;; TEST-ATOM-LEAF: atom.codegen.control.when.unless.while.zero
;; TEST-CLI-TARGET: codegen branches control-flow loops
(module Main)
(define x 0)
(when False (set! x 1))
(unless True (set! x 2))
(while False (set! x 3))
(show x)
(when True (set! x 4))
(unless False (set! x (+ x 1)))
(show x)
