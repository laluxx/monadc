(module Main)
(show (if True "yes" "no"))
(show (if False "yes" "no"))
(show (begin 1 2 3))
(show (and True True))
(show (and True False))
(show (or False True))
(show (or False False))
(show (not True))
(show (not False))
(unless False (show "executed"))
(show nil)
