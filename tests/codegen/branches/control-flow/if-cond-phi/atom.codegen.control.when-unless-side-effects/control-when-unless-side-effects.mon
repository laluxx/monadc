;; TEST-CLI-TARGET: codegen branches control-flow if-cond-phi
(module Main)
(define x 0)
(when True (set! x 1) (set! x (+ x 1)))
(when False (set! x 99))
(unless False (set! x (+ x 3)))
(unless True (set! x 100))
(show x)
