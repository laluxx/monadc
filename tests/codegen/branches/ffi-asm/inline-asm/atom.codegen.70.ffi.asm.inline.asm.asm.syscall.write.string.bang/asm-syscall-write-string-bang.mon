module AsmTest

define asm-write-bang :: Int -> String -> Int -> Int
  fd buf len -> (asm mov 1 %rax mov fd %rdi mov buf %rsi mov len %rdx syscall ret)

show (asm-write-bang 1 "hi" 2)
