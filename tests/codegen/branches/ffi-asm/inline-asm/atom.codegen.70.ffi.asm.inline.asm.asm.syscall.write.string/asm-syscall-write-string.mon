module AsmTest

define asm-sys-write :: Int -> String -> Int -> Int
  fd buf len -> (asm mov 1 %rax mov fd %rdi mov buf %rsi mov len %rdx syscall ret)

show (asm-sys-write 1 "ok" 2)
