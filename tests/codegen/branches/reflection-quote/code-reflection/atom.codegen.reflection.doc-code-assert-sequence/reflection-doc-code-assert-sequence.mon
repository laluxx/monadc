;; TEST-ATOM-LEAF: atom.codegen.reflection.doc-code-assert-sequence
;; TEST-CLI-TARGET: codegen branches reflection-quote code-reflection
(module Main)
(define plus1 :: Int -> Int
  "add one"
  x -> (+ x 1))
(show (Fn? plus1))
(show (doc plus1))
(show (code plus1))
(show (assert-eq (plus1 2) 3 "plus1"))
