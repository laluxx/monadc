;; TEST-CLI-TARGET: codegen branches reflection-quote code-reflection
(module Main)
(define documented :: Int -> Int
  "add one"
  x -> (+ x 1))
(show (Fn? documented))
(show (doc documented))
(show (code documented))
(show (assert-eq (documented 2) 3 "documented adds one"))
