(module Main)
(define (compose [f : Fn] [g : Fn] [x : Int] -> Int) (f (g x)))
(define a (lambda ([n : Int] -> Int) (+ n 1)))
(define b (lambda ([n : Int] -> Int) (* n 2)))
(show (compose a b 10))
