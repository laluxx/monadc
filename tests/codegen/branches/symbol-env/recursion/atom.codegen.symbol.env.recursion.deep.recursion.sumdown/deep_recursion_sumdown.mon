;; TEST-CLI-TARGET: codegen branches symbol-env recursion
(module Main)
(define (sumdown [n : Int] -> Int) (if (= n 0) 0 (+ n (sumdown (- n 1)))))
(show (sumdown 5))
(show (sumdown 1))
