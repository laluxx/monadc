(module Main)
(class Eq a where
  (=) :: a -> a -> Bool
  (!=) :: a -> a -> Bool)
(data TrafficLight Red | Yellow | Green deriving [Eq])
(show (= Red Red))
(show (= Red Green))
(show (!= Red Green))
(show (!= Red Red))
