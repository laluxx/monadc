;; TEST-ATOM-LEAF: atom.codegen.stateful.adt.enum.user.instance.defaults
;; TEST-CLI-TARGET: codegen branches data-layout adts

(import Data.Enum)
(data Dial D0 | D1 | D2)
(instance Enum Dial
  (toEnum n) => (if (= n 0) D0 (if (= n 1) D1 (if (= n 2) D2 (error "Dial.toEnum: out of bounds"))))
  (fromEnum x) => (match x with | D0 -> 0 | D1 -> 1 | D2 -> 2))
(show (fromEnum (succ D0)))
(show (fromEnum (pred D2)))
(show (count (enumFromTo D0 D2)))
(show (count (enumFromThenTo D0 D2 D2)))
