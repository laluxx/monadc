(module Main)
(layout Vec2 [x :: Int] [y :: Int])
(define (swap-components [v -> Vec2])
  (let [tmp v.x]
    (set! v.x v.y)
    (set! v.y tmp)))
(define v (Vec2 10 20))
(swap-components v)
(show v.x)
(show v.y)
