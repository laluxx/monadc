(module Main)
(data Maybe Nothing | Just Int)
(define (getOr [m : Maybe] [d : Int] -> Int)
  (match m with | Nothing -> d | (Just x) -> x))
(show (getOr Nothing 9))
(show (getOr (Just 4) 9))
