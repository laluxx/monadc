(module Main)
(layout Point [x :: Int] [y :: Int])
(layout Box [p :: Point] [tag :: Int])
(define b (Box (Point 1 2) 9))
(show b.p.x)
(set! b.p.x 77)
(show b.p.x)
(show b.tag)
