(module Main)
(layout Point [x :: Int] [y :: Int])
(data Shape Unit | Dot Point)
(define (score [s : Shape] -> Int)
  (match s with | Unit -> 0 | (Dot p) -> (+ p.x p.y)))
(show (score Unit))
(show (score (Dot (Point 2 5))))
