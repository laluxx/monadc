module Main

layout Color
  [r :: U8]
  [g :: U8]
  [b :: U8]
  where
    method fromRGB :: U8 -> U8 -> U8 -> Color
      r g b -> (Color r g b)

    method eql? :: Self -> Color -> Bool
      s o -> and s.r = o.r
                 s.g = o.g
                 s.b = o.b

define red   (Color 255 0 0)
define black (Color 0   0 0)

;; NOTE All 3 should work
define red (Color.fromRGB 255 0 0)
;; define red Color.fromRGB 255 0 0
;; define red Color.fromRGB(255 0 0)

show (red.eql? red)
show (red.eql? black)
