(module Main)
(define s {1 2})
(show (Set? s))
(show (collection? s))
(show (contains? s 1))
(show (contains? (conj s 3) 3))
(show (contains? s 3))
(conj! s 3)
(show (contains? s 3))
(disj! s 1)
(show (contains? s 1))
