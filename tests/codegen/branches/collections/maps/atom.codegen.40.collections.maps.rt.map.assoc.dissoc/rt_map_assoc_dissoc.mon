(module Main)
(define palette #{:red 1 :green 2 :blue 3})
(show (Map? palette))
(show (count palette))
(show (contains? palette :green))
(show (contains? palette :cyan))
(show (find palette :blue))
(show (keys palette))
(show (vals palette))
