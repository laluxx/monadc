(module Main)
(define m #{:a 1})
(show (Map? m))
(show (count m))
(show (contains? m :a))
(define m2 (assoc m :b 2))
(show (count m))
(show (count m2))
(assoc! m :b 2)
(show (count m))
(dissoc! m :a)
(show (count m))
