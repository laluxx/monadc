(module Main)
(define [s :: Set] {1 2 3})
(conj! s 4)
(show (contains? s 4))
(disj! s 1)
(show (contains? s 1))
(show (count s))

(define [xs :: List] (list))
(append! xs 10)
(append! xs 20)
(show (car xs))
(show (car (cdr xs)))

(show (collection? s))
(show (collection? xs))
(show (collection? 42))
