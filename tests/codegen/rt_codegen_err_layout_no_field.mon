;; TEST-ID: tests.codegen.rt-codegen-err-layout-no-field
;; TEST-SECTION: diagnostic
;; TEST-CONTEXT: monadc.context.language.codegen-diagnostics
;; TEST-PURPOSE: Codegen rejects access to missing layout fields.
;; TEST-ATOM: p.z must fail when Point only has field x.
;; TEST-EXPECT: fail:compile

(module Main)
(layout Point [x :: Int])
(define p (Point 1))
(show p.z)
