;; TEST-ID: tests.codegen.rt-assign-arrow-sugar
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime assignment-arrow sugar mutates variables.
;; TEST-ATOM: x <- value desugars to set! and updates x.
;; TEST-EXPECT: compile, run

(module Main)
(define x 0)
x <- 5
(show x)
x <- x + 2
(show x)
