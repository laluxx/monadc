;; TEST-ID: tests.codegen.rt-for-loop-nested
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime nested for loops produce correct product sum.
;; TEST-ATOM: Two nested loops summing i*j over i=[0,3), j=[0,2) = 0+0+0+1+0+2 = 3? Actually 0*0+0*1+1*0+1*1+2*0+2*1 = 0+0+0+1+0+2 = 3.
;; TEST-EXPECT: compile, run

(module Main)
(define total 0)
(for [i 0 3]
  (for [j 0 2]
    (set! total (+ total (* i j)))))
(show total)
