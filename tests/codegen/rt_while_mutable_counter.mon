;; TEST-ID: tests.codegen.rt-while-mutable-counter
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: While loop with mutable counter works.
;; TEST-ATOM: (while (< i 3) (set! i (+ i 1))) increments i from 0 to 3.
;; TEST-EXPECT: compile, run

(module Main)
(define i 0)
(while (< i 3)
  (begin
    (show i)
    (set! i (+ i 1))))
