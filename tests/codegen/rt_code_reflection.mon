;; TEST-ID: tests.codegen.rt-code-reflection
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime code reflection attempts to retrieve source for a defined function.
;; TEST-ATOM: (code inc) is a codegen-backed coverage point for function source retention.
;; TEST-EXPECT: compile, run

(module Main)
(define (inc [x : Int] -> Int) (+ x 1))
(show (Fn? inc))
(show (code inc))
