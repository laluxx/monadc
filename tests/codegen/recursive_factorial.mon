;; TEST-ID: tests.codegen.recursive-factorial
;; TEST-CONTEXT: monadc.context.language.syntax-corpus
;; TEST-PURPOSE: Recursive factorial computes correctly.
;; TEST-ATOM: Factorial of 7 is 5040.
;; TEST-EXPECT: compile, run

(module Main)
(define (fact [n : Int] -> Int)
  (if (<= n 1) 1 (* n (fact (- n 1)))))
(show (fact 7))
