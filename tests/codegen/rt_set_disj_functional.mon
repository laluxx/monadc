;; TEST-ID: tests.codegen.rt-set-disj-functional
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: disj (functional) returns a new set with the element removed, leaving original unchanged.
;; TEST-ATOM: (disj s 2) returns new set {1 3}; original set {1 2 3} unchanged.
;; TEST-EXPECT: compile, run

(module Main)
(define [s :: Set] {1 2 3})
(define [s2 :: Set] (disj s 2))
(show (contains? s2 2))
(show (contains? s 2))
(show (count s2))
