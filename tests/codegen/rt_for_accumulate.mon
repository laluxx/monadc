;; TEST-ID: tests.codegen.rt-for-accumulate
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime for loop can update an accumulator.
;; TEST-ATOM: (for [i 0 4] ...) visits 0,1,2,3 and sums to 6.
;; TEST-EXPECT: compile, run

(module Main)
(define total 0)
(for [i 0 4]
  (set! total (+ total i)))
(show total)
