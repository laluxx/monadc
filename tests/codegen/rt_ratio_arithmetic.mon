;; TEST-ID: tests.codegen.rt-ratio-arithmetic
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime ratio literal arithmetic.
;; TEST-ATOM: Addition and multiplication of ratios produces correct exact results.
;; TEST-EXPECT: compile, run

(module Main)
(show (+ 1/2 1/3))
(show (- 3/4 1/4))
(show (* 2/3 3/4))
(show (/ 5/6 5/6))
