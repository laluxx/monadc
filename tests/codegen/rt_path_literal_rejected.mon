;; TEST-ID: tests.codegen.rt-path-literal-rejected
;; TEST-CONTEXT: monadc.context.reader.path-literals, monadc.context.language.path-literals, monadc.context.tests.expected-failures
;; TEST-PURPOSE: Verify parsed Unix path literals are rejected before they become runtime values.
;; TEST-ATOM: A syntactically valid home-relative Unix path literal in a define must be a compile-time type error; use a String literal for filesystem path values.
;; TEST-EXPECT: fail:compile
;; TEST-EXPECT-DIAGNOSTIC: error: ill-typed path literal

(module PathLiteralRejected)

(define path ~/xos/projects/c/monadc/context/)
(show path)
