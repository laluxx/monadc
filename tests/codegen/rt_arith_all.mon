;; TEST-ID: tests.codegen.rt-arith-all
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Complete arithmetic operator coverage: + - * / mod % with various arg counts, mixed types.
;; TEST-ATOM: (+ 1 2) = 3, (+ 1 2 3 4) = 10, (- 10 3) = 7, (* 2 3 4) = 24, (/ 10 3) = 3, (/ 10.0 3.0) = 3.33..., (mod 10 3) = 1, (% 10 3) = 1
;; TEST-EXPECT: compile, run
(module Main)
(show (+ 1 2))
(show (+ 1 2 3 4))
(show (- 10 3))
(show (* 2 3 4))
(show (/ 10 3))
(show (/ 10.0 3.0))
(show (mod 10 3))
(show (% 10 3))
