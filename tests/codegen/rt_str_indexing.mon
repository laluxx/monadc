;; TEST-ID: tests.codegen.rt-str-indexing
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: String indexing with integer index (codegen handle_atom pattern).
;; TEST-ATOM: ("hello" 0) = #\h, ("hello" 1) = #\e, ("hello" 4) = #\o,
;;           (define s "abc") then (s 2) = #\c
;; TEST-EXPECT: compile, run
(module Main)
(show ("hello" 0))
(show ("hello" 4))
(define s "abc")
(show (s 2))
