;; TEST-ID: tests.codegen.pattern-match
;; TEST-CONTEXT: monadc.context.language.syntax-corpus, monadc.context.reader.match-syntax
;; TEST-PURPOSE: Pattern matching compiles and evaluates clauses correctly.
;; TEST-ATOM: (match 1 with | 0 -> 10 | 1 -> 20 | _ -> 30) evaluates to 20.
;; TEST-EXPECT: compile, run

(module Main)
(show (match 1 with | 0 -> 10 | 1 -> 20 | _ -> 30))

;; WISP:

show match 1
  with
    0 -> 10
    1 -> 20
    _ -> 30
