;; TEST-ID: tests.codegen.rt-layout-nested-fields
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus, monadc.context.language.layout-records
;; TEST-PURPOSE: Multiple layouts can be declared, constructed, and read in one module.
;; TEST-ATOM: Color and Pixel constructors coexist and expose their direct fields.
;; TEST-EXPECT: compile, run

(module Main)
(layout Color [r :: Int] [g :: Int] [b :: Int])
(layout Pixel [x :: Int] [y :: Int] [color :: Color])
(define px (Pixel 10 20 (Color 255 64 0)))
(define c (Color 255 64 0))
(show px.x)
(show px.y)
(show c.r)
(show c.g)
(show c.b)
