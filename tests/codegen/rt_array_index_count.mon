;; TEST-ID: tests.codegen.rt-array-index-count
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime array indexing and count work together on a bound array value.
;; TEST-ATOM: count returns 3 for [1 2 3] and postfix index retrieves the middle element.
;; TEST-EXPECT: compile, run

(module Main)
(define xs [1 2 3])
(show (count xs))
(show xs[1])
