;; TEST-ID: tests.codegen.rt-layout-color-methods
;; TEST-CONTEXT: monadc.context.wisp.limitations, monadc.context.language.layout-records
;; TEST-PURPOSE: Desired layout-local method syntax is captured as an expected compiler gap.
;; TEST-ATOM: Color.fromRGB and red.eql red should eventually compile as layout methods.
;; TEST-EXPECT: fail:compile

module Main

layout Color
  [r :: U8]
  [g :: U8]
  [b :: U8]
  where
    method fromRGB :: U8 -> U8 -> U8 -> Color
      r g b -> Color r g b

    method eql :: Self -> Color -> Bool
      s o -> and s.r = o.r
                 s.g = o.g
                 s.b = o.b

define red Color.fromRGB 255 0 0
show red.eql red
