;; TEST-ID: tests.codegen.wisp-define
;; TEST-CONTEXT: monadc.context.language.syntax-corpus, monadc.context.wisp.typed-define-pattern-params
;; TEST-PURPOSE: Wisp-style define compiles and runs correctly.
;; TEST-ATOM: A Wisp-defined function square :: Int -> Int binds the body-clause variable x instead of leaving it unbound.
;; TEST-EXPECT: compile, run

(module Main)

define square :: Int -> Int
  x -> x * x

(show (square 12))
