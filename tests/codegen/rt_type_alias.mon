;; TEST-ID: tests.codegen.rt-type-alias
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime type aliases can annotate values that reach codegen.
;; TEST-ATOM: Str aliases String for a typed define.
;; TEST-EXPECT: compile, run

(module Main)
(type Str String)
(define [name :: Str] "monad")
(show name)
