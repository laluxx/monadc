;; TEST-ID: tests.codegen.rt-cffi-string-strcmp
;; TEST-SECTION: cffi
;; TEST-CONTEXT: monadc.context.language.cffi-runtime
;; TEST-PURPOSE: Runtime C FFI calls strcmp and observes equality as zero.
;; TEST-ATOM: (strcmp "ada" "ada") prints 0.
;; TEST-EXPECT: compile, run

(module Main)
(include "string.h")
(show (strcmp "ada" "ada"))
