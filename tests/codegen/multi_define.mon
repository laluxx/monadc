;; TEST-ID: tests.codegen.multi-define
;; TEST-CONTEXT: monadc.context.language.syntax-corpus
;; TEST-PURPOSE: Multiple top-level defines compile and interact correctly.
;; TEST-ATOM: Two defines and their usage in show evaluates correctly.
;; TEST-EXPECT: compile, run

(module Main)
(define x 10)
(define y 20)
(show (+ x y))
