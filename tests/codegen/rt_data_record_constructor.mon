;; TEST-ID: tests.codegen.rt-data-record-constructor
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus, monadc.context.language.layout-records
;; TEST-PURPOSE: Runtime record-like values use layout declarations, not ADT brace fields.
;; TEST-ATOM: (layout Person [name :: String] [age :: Int]) constructs and exposes named fields.
;; TEST-EXPECT: compile, run

(module Main)
(layout Person [name :: String] [age :: Int])
(define p (Person "ada" 37))
(show p.name)
(show p.age)
