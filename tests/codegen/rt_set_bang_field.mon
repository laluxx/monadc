;; TEST-ID: tests.codegen.rt-set-bang-field
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Set! on layout field mutates the field value.
;; TEST-ATOM: (set! (p . x) 5) changes p.x from 3 to 5.
;; TEST-EXPECT: compile, run

(module Main)
(layout Point [x :: Int] [y :: Int])
(define p (Point 3 4))
(set! (p . x) 5)
(show p.x)
(show p.y)
