;; TEST-ID: tests.codegen.rt-wisp-maps-percentages
;; TEST-CONTEXT: monadc.context.wisp.sugar-transforms, monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Wisp syntax combines map literals, percentage literals, and infix comparison.
;; TEST-ATOM: A Wisp module binds a map and percent value, queries the map, and prints normalized percentage values.
;; TEST-EXPECT: compile, run

module Main

define rates #{:vat 22% :half 50%}
define half 50%

show Map? rates
show count rates
show find rates :vat
show half
