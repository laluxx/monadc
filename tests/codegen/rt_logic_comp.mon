;; TEST-ID: tests.codegen.rt-logic-comp
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Logic ops and/or/not with short-circuit, all truth combos
;; TEST-ATOM: (and True True) = True, (and True False) = False, (or False True) = True, (or False False) = False, (not True) = False, (not False) = True
;; TEST-EXPECT: compile, run
(module Main)
(show (and True True))
(show (and True False))
(show (or False True))
(show (or False False))
(show (not True))
(show (not False))
