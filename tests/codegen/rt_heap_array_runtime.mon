;; TEST-ID: tests.codegen.rt-heap-array-runtime
;; TEST-CONTEXT: monadc.context.reader.heap-arrays, monadc.context.language.runtime-sized-arrays, monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime codegen treats heap array literals as runtime-sized arrays.
;; TEST-ATOM: ~[1 2 3] must show as [1 2 3], count as 3, support array-as-function indexing, head, and tail.
;; TEST-EXPECT: json:ast, compile, run

(module Main)
(define heap ~[1 2 3])
(show heap)
(show (count heap))
(show (heap 1))
(show (head heap))
(show (tail heap))
