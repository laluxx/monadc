;; TEST-ID: tests.codegen.rt-map-key-family-lookup
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Map query syntax supports keyword, string, and integer key families in one literal.
;; TEST-ATOM: find observes keys from different token families through current runtime display semantics.
;; TEST-EXPECT: compile, run

(module Main)
(define m #{:k 10 "s" 20 7 "seven"})
(show (Map? m))
(show (count m))
(show (find m :k))
(show (find m "s"))
(show (find m 7))
