;; TEST-ID: tests.codegen.rt-if-else-chain
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Chained if-else-if-else pattern works.
;; TEST-ATOM: (if (> x 0) 1 (if (< x 0) -1 0)) returns sign.
;; TEST-EXPECT: compile, run

(module Main)
(define (sign [x : Int] -> Int)
  (if (> x 0) 1 (if (< x 0) -1 0)))
(show (sign 5))
(show (sign -3))
(show (sign 0))
