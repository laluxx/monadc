;; TEST-ID: tests.codegen.rt-type-alias-value
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Type alias used in a value binding compiles.
;; TEST-ATOM: (type Age Int) then (define [n :: Age] 42) then show prints 42.
;; TEST-EXPECT: compile, run

(module Main)
(type Age Int)
(define [n :: Age] 42)
(show n)
