;; TEST-ID: tests.codegen.rt-wisp-sexpr-mix
;; TEST-CONTEXT: monadc.context.wisp.sexpr-mixing
;; TEST-PURPOSE: Wisp and S-exprs mix freely
;; TEST-ATOM: s-expr forms can be embedded in wisp code
;; TEST-EXPECT: compile, run
module Main
show (+ 1 2)
show (* 3 4)
show (- 10 5)
define xs '(1 2 3)
show car xs
show car '(10 20 30)
