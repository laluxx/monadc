;; TEST-CONTEXT: monadc.context.language.syntax-corpus
;; TEST-PURPOSE: Runtime bitwise xor, not, and logical right shift work.
;; TEST-ATOM: (bit-xor 5 3) = 6, (~ 42) = -43, (>>> 16 2) = 4.
