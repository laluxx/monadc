;; TEST-ID: tests.codegen.rt-set-operations
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime set literal predicates and queries.
;; TEST-ATOM: Set? and count on set variables; contains? on inline set literals.
;; TEST-EXPECT: compile, run

(module Main)
(define s {10 20})
(show (Set? s))
(show (contains? {10 20} 20))
(show (contains? {10 20} 99))
(show (count s))
