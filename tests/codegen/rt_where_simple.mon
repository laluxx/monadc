;; TEST-ID: tests.codegen.rt-where-simple
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Where clause provides local value bindings.
;; TEST-ATOM: f x -> result where result = x + 1 evaluates f 5 to 6.
;; TEST-EXPECT: compile, run

(module Main)
(define (f [x :: Int] -> Int)
  (let [result (+ x 1)] result))
(show (f 5))
