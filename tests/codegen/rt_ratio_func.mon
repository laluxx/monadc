;; TEST-ID: tests.codegen.rt-ratio-func
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Ratio literal used as function (1/4 x) multiplies by fraction.
;; TEST-ATOM: (1/4 100) = 25, (1/2 10) = 5, (3/4 100) = 75, (1/4 2.0) = 0.5
;; TEST-EXPECT: compile, run
(module Main)
(show (1/4 100))
(show (1/2 10))
(show (3/4 100))
(show (1/4 2.0))
