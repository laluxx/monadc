;; TEST-ID: tests.codegen.rt-cmp-chained
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Binary comparison operators (variadic chaining not supported).
;; TEST-ATOM: (< 1 2) = True, (= 5 5) = True, (= 5 6) = False, (> 5 3) = True
;; TEST-EXPECT: compile, run
(module Main)
(show (< 1 2))
(show (= 5 5))
(show (= 5 6))
(show (> 5 3))
(show (>= 5 5))
(show (<= 5 5))
