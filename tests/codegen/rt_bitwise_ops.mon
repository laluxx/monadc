;; TEST-ID: tests.codegen.rt-bitwise-ops
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Bitwise operations on integers (only & and ~ work; | is reserved for pipe).
;; TEST-ATOM: (& 12 5) = 4, (~ 0) = -1, (~ -1) = 0
;; TEST-EXPECT: compile, run
(module Main)
(show (& 12 5))
(show (~ 0))
(show (~ -1))
