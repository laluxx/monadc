;; TEST-ID: tests.codegen.rt-for-backward
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: For loop with backward arrow iterates over string in reverse.
;; TEST-ATOM: (for c <- "cba" (show c)) prints c, b, a.
;; TEST-EXPECT: compile, run

;; TEST-ID: tests.codegen.rt-for-backward
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: For loop with backward arrow iterates over string in reverse.
;; TEST-ATOM: (for c <- "cba" (show c)) prints c, b, a.
;; TEST-EXPECT: compile, run

module Main

for c <- "cba"
  show c

(for c -> "abc"
  (show c))
