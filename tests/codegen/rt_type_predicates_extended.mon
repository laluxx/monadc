;; TEST-ID: tests.codegen.rt-type-predicates-extended
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime type predicates cover collection, boolean, numeric, and function values.
;; TEST-ATOM: List?, Arr?, Bool?, Number?, and Fn? return expected booleans.
;; TEST-EXPECT: compile, run

(module Main)
(show (List? '(1 2)))
(show (Arr? [1 2]))
(show (Bool? True))
(show (Number? 42))
(show (Fn? (lambda (x) x)))
