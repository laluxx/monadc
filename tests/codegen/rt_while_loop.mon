;; TEST-ID: tests.codegen.rt-while-loop
;; TEST-CONTEXT: monadc.context.language.syntax-corpus
;; TEST-PURPOSE: Runtime while loop evaluates correctly.
;; TEST-ATOM: (while (< i 3) ...) loops 3 times.
;; TEST-EXPECT: compile, run

(module Main)
(define i 0)
(while (< i 3) (begin (show i) (set! i (+ i 1))))
