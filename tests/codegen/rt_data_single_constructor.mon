;; TEST-ID: tests.codegen.rt-data-single-constructor
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Data type with single parameterized constructor works.
;; TEST-ATOM: (data Point Float Float) then (Point 3.0 4.0) creates a value.
;; TEST-EXPECT: compile, run

(module Main)
(data Point Float Float)
(define p (Point 3.0 4.0))
(show p)
