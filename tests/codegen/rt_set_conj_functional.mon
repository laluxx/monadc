;; TEST-ID: tests.codegen.rt-set-conj-functional
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: conj (functional) returns a new set with the element added, leaving original unchanged.
;; TEST-ATOM: (conj s 3) returns new set {1 2 3}; original set {1 2} unchanged.
;; TEST-EXPECT: compile, run

(module Main)
(define [s :: Set] {1 2})
(define [s2 :: Set] (conj s 3))
(show (contains? s2 3))
(show (contains? s 3))
(show (count s2))
