;; TEST-ID: tests.codegen.rt-equal-all
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: equal? with int, string, list, set values
;; TEST-ATOM: (equal? 1 1) = True, (equal? 1 2) = False, (equal? "a" "a") = True, (equal? '(1 2) '(1 2)) = True, (equal? '(1 2) '(3 4)) = False
;; TEST-EXPECT: compile, run
(module Main)
(show (equal? 1 1))
(show (equal? 1 2))
(show (equal? "a" "a"))
(show (equal? '(1 2) '(1 2)))
(show (equal? '(1 2) '(3 4)))
