;; TEST-ID: tests.codegen.rt-primitive-edge-cases
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Edge cases for primitive operations: divide by zero, modulo.
;; TEST-ATOM: (/ 0 1) = 0, (% 10 3) = 1, (% -10 3) = 2, (% 10 -3) = -2
;; TEST-EXPECT: compile, run
(module Main)
(show (/ 0 1))
(show (% 10 3))
(show (% -10 3))
(show (% 10 -3))
