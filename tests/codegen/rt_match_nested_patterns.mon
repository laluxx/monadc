;; TEST-ID: tests.codegen.rt-match-nested-patterns
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Nested match patterns destructure nested lists.
;; TEST-ATOM: (match '(1 2 3) with [x|xs] -> (show x) (show xs))
;; TEST-EXPECT: compile, run

(module Main)
(match '(1 2 3) with
  [x|xs] -> (begin (show x) (show xs))
  []     -> (show 0))
