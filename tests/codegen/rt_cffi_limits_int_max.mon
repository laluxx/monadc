;; TEST-ID: tests.codegen.rt-cffi-limits-int-max
;; TEST-SECTION: cffi
;; TEST-CONTEXT: monadc.context.language.cffi-runtime
;; TEST-PURPOSE: Runtime C FFI exposes integer constants from included headers.
;; TEST-ATOM: INT_MAX from limits.h is greater than zero.
;; TEST-EXPECT: compile, run

(module Main)
(include "limits.h")
(show (> INT_MAX 0))
