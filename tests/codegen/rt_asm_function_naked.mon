;; TEST-ID: tests.codegen.rt-asm-function-naked
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Inline asm in a naked function body — raw register manipulation.
;;   Currently returns first param only; the add instruction result is not propagated.
;; TEST-ATOM: (asm ...) inside naked function — documents naked asm gap.
;; TEST-EXPECT: compile, run

(module Main)
(define (add [x : Int] [y : Int] -> Int)
  :naked True
  (asm
    push %rbp
    mov  %rsp %rbp
    mov  x    %rax
    add  y    %rax
    pop  %rbp
    ret))
(show (add 60 70))
