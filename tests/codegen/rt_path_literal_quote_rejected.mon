;; TEST-ID: tests.codegen.rt-path-literal-quote-rejected
;; TEST-CONTEXT: monadc.context.reader.path-literals, monadc.context.language.path-literals, monadc.context.tests.expected-failures
;; TEST-PURPOSE: Verify quoted Unix path literals are rejected before they become runtime values.
