;; TEST-ID: tests.codegen.rt-map-filter-pipe
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Map and filter with pipe-forward chains correctly.
;; TEST-ATOM: Filter evens then double: (filter even? xs) |> (map double).
;; TEST-EXPECT: compile, run

(module Main)
(define (double [x :: Int] -> Int) (* 2 x))
(define xs [1 2 3 4 5 6])
(show (map double (filter (lambda (x) (= (% x 2) 0)) xs)))
