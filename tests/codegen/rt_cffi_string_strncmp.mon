;; TEST-ID: tests.codegen.rt-cffi-string-strncmp
;; TEST-SECTION: cffi
;; TEST-CONTEXT: monadc.context.language.cffi-runtime
;; TEST-PURPOSE: Runtime C FFI calls strncmp with a size argument.
;; TEST-ATOM: (strncmp "abcdef" "abcxyz" 3) prints 0.
;; TEST-EXPECT: compile, run

(module Main)
(include "string.h")
(show (strncmp "abcdef" "abcxyz" 3))
