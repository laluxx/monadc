;; TEST-ID: tests.codegen.rt-superscript-sugar
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime superscript sugar is a codegen-backed coverage point for exponent calls.
;; TEST-ATOM: x² and x³ desugar to (^ x 2) and (^ x 3).
;; TEST-EXPECT: compile, run

(module Main)
(define x 5)
(show x²)
(show x³)
