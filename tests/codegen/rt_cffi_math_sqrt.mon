;; TEST-ID: tests.codegen.rt-cffi-math-sqrt
;; TEST-SECTION: cffi
;; TEST-CONTEXT: monadc.context.language.cffi-runtime
;; TEST-PURPOSE: Runtime C FFI calls into libm sqrt through an include-backed symbol.
;; TEST-ATOM: (include "math.h") with (sqrt 16.0) prints 4.
;; TEST-EXPECT: compile, run

(module Main)
(include "math.h")
(show (sqrt 16.0))
