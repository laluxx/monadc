;; TEST-ID: tests.codegen.rt-unless-skip
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime unless skips its body when the condition is true.
;; TEST-ATOM: (unless True (set! x 7)) leaves x unchanged.
;; TEST-EXPECT: compile, run

(module Main)
(define x 0)
(unless True (set! x 7))
(show x)
