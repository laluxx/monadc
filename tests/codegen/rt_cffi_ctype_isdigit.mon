;; TEST-ID: tests.codegen.rt-cffi-ctype-isdigit
;; TEST-SECTION: cffi
;; TEST-CONTEXT: monadc.context.language.cffi-runtime
;; TEST-PURPOSE: Runtime C FFI calls a ctype predicate-like function.
;; TEST-ATOM: (isdigit 57) returns a nonzero C int for ASCII '9'.
;; TEST-EXPECT: compile, run

(module Main)
(include "ctype.h")
(show (> (isdigit 57) 0))
