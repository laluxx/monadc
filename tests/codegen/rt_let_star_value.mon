;; TEST-ID: tests.codegen.rt-let-star-value
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: let* binding chains where later bindings use earlier values.
;; TEST-ATOM: (let* [x 1 y (+ x 1)]) evaluates y = 2.
;; TEST-EXPECT: compile, run

(module Main)
(let* [x 1]
  (let* [y (+ x 1)]
    (show y)))
