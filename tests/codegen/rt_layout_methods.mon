;; TEST-ID: tests.codegen.rt-layout-methods
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Layout methods with where syntax dispatch correctly.
;; TEST-ATOM: Vec3 layout with ->array method returns [x y z].
;; TEST-EXPECT: compile, run

module Main

layout Color
  [r :: U8]
  [g :: U8]
  [b :: U8]
  where
    method fromRGB :: U8 -> U8 -> U8 -> Color
      r g b -> (Color r g b)

    method eql :: Self -> Color -> Bool
      s o -> and s.r = o.r
                 s.g = o.g
                 s.b = o.b

define red (Color 255 0 0)
define red (Color.fromRGB 255 0 0)
show (red.eql red)
