;; TEST-ID: tests.codegen.rt-begin-define-inline
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Begin with multiple defines and a show.
;; TEST-ATOM: (begin (define x 1) (define y 2) (show (+ x y))) prints 3.
;; TEST-EXPECT: compile, run

(module Main)
(begin
  (define x 1)
  (define y 2)
  (show (+ x y)))
