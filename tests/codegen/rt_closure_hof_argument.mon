;; TEST-ID: tests.codegen.rt-closure-hof-argument
;; TEST-CONTEXT: monadc.context.language.type-system-surface, monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Closure codegen pressure for passing a function value as a typed Fn parameter.
;; TEST-ATOM: apply1 should call a function argument through the runtime closure ABI.
;; TEST-EXPECT: compile, run

(module Main)
(define apply1 (lambda ([f : Fn] [x : Int] -> Int) (f x)))
(define inc (lambda ([x : Int] -> Int) (+ x 1)))
(show (apply1 inc 41))
