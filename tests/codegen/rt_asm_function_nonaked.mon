;; TEST-ID: tests.codegen.rt-asm-function-nonaked
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Inline asm in a non-naked function body — size-suffix inference
;;   currently generates 32-bit (l) suffix for Int parameters, causing LLVM error.
;; TEST-ATOM: (asm add x y) inside non-naked function — documents size-suffix gap.
;; TEST-EXPECT: compile, run

(module Main)
(define (add [x : Int] [y : Int] -> Int)
  :naked False
  (asm add x y))
(show (add 10 20))
