;; TEST-ID: tests.codegen.asm.int-and-immediate
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Immediate and uses escaped LLVM inline-asm immediates.
;; TEST-ATOM: and x 63 returns x & 63.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-and-imm :: Int -> Int
  x -> (asm and x 63)

show (asm-and-imm 106)
