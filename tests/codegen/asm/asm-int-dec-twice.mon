;; TEST-ID: tests.codegen.asm.int-dec-twice
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Repeated decrement operations stay in the tied output register.
;; TEST-ATOM: dec x dec x returns x - 2.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-dec2 :: Int -> Int
  x -> (asm dec x dec x)

show (asm-dec2 44)
