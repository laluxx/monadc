;; TEST-ID: tests.codegen.asm.int-imul-then-add-immediate
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Immediate add after multiplication preserves instruction order.
;; TEST-ATOM: imul a b then add a 2 returns a*b + 2.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-mul-add :: Int -> Int -> Int
  a b -> (asm imul a b add a 2)

show (asm-mul-add 8 5)
