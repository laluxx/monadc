;; TEST-ID: tests.codegen.asm.int-add-two-params
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Two-operand add uses destination/source rewriting.
;; TEST-ATOM: add a b returns a + b through the tied output/input constraint.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-add :: Int -> Int -> Int
  a b -> (asm add a b)

show (asm-add 20 22)
