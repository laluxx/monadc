;; TEST-ID: tests.codegen.asm.int-add-immediate
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Immediate add uses escaped LLVM inline-asm immediates.
;; TEST-ATOM: add x 5 emits an immediate add and returns x + 5.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-add-imm :: Int -> Int
  x -> (asm add x 5)

show (asm-add-imm 37)
