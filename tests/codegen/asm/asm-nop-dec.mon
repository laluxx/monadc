;; TEST-ID: tests.codegen.asm.nop-dec
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Decrement works after a no-op stream.
;; TEST-ATOM: nop dec x returns x - 1.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-nop-dec :: Int -> Int
  x -> (asm nop dec x)

show (asm-nop-dec 43)
