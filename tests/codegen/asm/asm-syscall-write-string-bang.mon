;; TEST-ID: tests.codegen.asm.syscall-write-string-bang
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: String operand syscall test uses real side effects safely.
;; TEST-ATOM: write(2) returns the requested byte count after writing to stdout.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-write-bang :: Int -> String -> Int -> Int
  fd buf len -> (asm mov 1 %rax mov fd %rdi mov buf %rsi mov len %rdx syscall ret)

show (asm-write-bang 1 "hi" 2)
