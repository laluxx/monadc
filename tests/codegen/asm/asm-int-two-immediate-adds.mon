;; TEST-ID: tests.codegen.asm.int-two-immediate-adds
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Two immediate adds can be chained.
;; TEST-ATOM: add x 20 then add x 2 returns x + 22.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-add-imm2 :: Int -> Int
  x -> (asm add x 20 add x 2)

show (asm-add-imm2 20)
