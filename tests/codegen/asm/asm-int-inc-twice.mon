;; TEST-ID: tests.codegen.asm.int-inc-twice
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Repeated unary operations stay in the tied output register.
;; TEST-ATOM: inc x inc x returns x + 2.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-inc2 :: Int -> Int
  x -> (asm inc x inc x)

show (asm-inc2 40)
