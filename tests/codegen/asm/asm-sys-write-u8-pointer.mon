;; TEST-ID: tests.codegen.asm.sys-write-u8-pointer
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Inline asm functions accept pointer-sugar parameter types.
;; TEST-ATOM: A function body using the user-facing sys-write shape with *U8 must compile.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-sys-write-u8 :: Int -> *U8 -> Int -> Int
  fd buf len -> (asm mov 1 %rax mov fd %rdi mov buf %rsi mov len %rdx syscall ret)

show 42
