;; TEST-ID: tests.codegen.asm.cmov-max
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Conditional move selects a maximum without language-level branching.
;; TEST-ATOM: cmp plus cmovg returns b when b is greater than a.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-cmov-max :: Int -> Int -> Int
  a b -> (asm cmp a b cmovg b a)

show (asm-cmov-max 20 42)
