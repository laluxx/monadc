;; TEST-ID: tests.codegen.asm.int-add-then-sub
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: A mixed add/sub instruction stream preserves order.
;; TEST-ATOM: add a b then sub a c returns a + b - c.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-add-sub :: Int -> Int -> Int -> Int
  a b c -> (asm add a b sub a c)

show (asm-add-sub 50 10 18)
