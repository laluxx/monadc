;; TEST-ID: tests.codegen.asm.int-inc
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Unary inc mutates the tied output register.
;; TEST-ATOM: inc x returns x + 1.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-inc :: Int -> Int
  x -> (asm inc x)

show (asm-inc 41)
