;; TEST-ID: tests.codegen.asm.rol-one-bit
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Rotate-left accepts an immediate count and tied Int output.
;; TEST-ATOM: rol 1 x doubles 21 by rotating within a 64-bit register.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-rol1 :: Int -> Int
  x -> (asm rol 1 x)

show (asm-rol1 21)
