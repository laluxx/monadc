;; TEST-ID: tests.codegen.asm.int-sub-then-add
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: A mixed sub/add instruction stream preserves order.
;; TEST-ATOM: sub a b then add a c returns a - b + c.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-sub-add :: Int -> Int -> Int -> Int
  a b c -> (asm sub a b add a c)

show (asm-sub-add 50 20 12)
