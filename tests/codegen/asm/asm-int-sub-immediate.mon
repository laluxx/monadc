;; TEST-ID: tests.codegen.asm.int-sub-immediate
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Immediate sub uses escaped LLVM inline-asm immediates.
;; TEST-ATOM: sub x 8 returns x - 8.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-sub-imm :: Int -> Int
  x -> (asm sub x 8)

show (asm-sub-imm 50)
