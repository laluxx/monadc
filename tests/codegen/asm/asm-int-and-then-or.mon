;; TEST-ID: tests.codegen.asm.int-and-then-or
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Logical instruction stream preserves order.
;; TEST-ATOM: and a b then or a c returns (a & b) | c.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-and-or :: Int -> Int -> Int -> Int
  a b c -> (asm and a b or a c)

show (asm-and-or 47 40 2)
