;; TEST-ID: tests.codegen.asm.cmov-min
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Conditional move selects a minimum without language-level branching.
;; TEST-ATOM: cmp plus cmovl returns b when b is less than a.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-cmov-min :: Int -> Int -> Int
  a b -> (asm cmp a b cmovl b a)

show (asm-cmov-min 50 42)
