;; TEST-ID: tests.codegen.asm.mov-then-add
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Parameter mov can be followed by integer arithmetic.
;; TEST-ATOM: mov x %rax ret-style setup plus add keeps the return value meaningful.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-mov-add :: Int -> Int
  x -> (asm mov x %rax add x 2)

show (asm-mov-add 40)
