;; TEST-ID: tests.codegen.asm.nop-after-add
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: A no-op instruction can follow a real mutation.
;; TEST-ATOM: add a b nop returns a + b.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-add-nop :: Int -> Int -> Int
  a b -> (asm add a b nop)

show (asm-add-nop 20 22)
