;; TEST-ID: tests.codegen.asm.char-return-from-param
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Char return type selects byte-sized LLVM return type.
;; TEST-ATOM: mov x %al returns a Char from an integer byte.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-char :: Int -> Char
  x -> (asm mov x %al ret)

show (asm-char 65)
