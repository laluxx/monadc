;; TEST-ID: tests.codegen.asm.int-arithmetic-shift-right
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Arithmetic shift with an immediate handles signed negatives.
;; TEST-ATOM: sar 1 x returns x arithmetic-shifted right by one.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-sar1 :: Int -> Int
  x -> (asm sar 1 x)

show (asm-sar1 84)
