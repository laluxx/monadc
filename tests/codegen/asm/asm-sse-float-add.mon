;; TEST-ID: tests.codegen.asm.sse-float-add
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: SSE scalar addition combines language Float arguments.
;; TEST-ATOM: addsd b a returns a + b through xmm tied output constraints.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-float-add :: Float -> Float -> Float
  a b -> (asm addsd b a)

show (asm-float-add 1.5 2.25)
