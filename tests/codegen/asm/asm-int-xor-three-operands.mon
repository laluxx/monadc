;; TEST-ID: tests.codegen.asm.int-xor-three-operands
;; TEST-SECTION: codegen
;; TEST-CONTEXT: monadc.context.reader.sugar.inline-assembly, monadc.context.language.inline-asm, monadc.context.language.codegen
;; TEST-PURPOSE: Xor instruction stream preserves order.
;; TEST-ATOM: xor a b then xor a c returns a ^ b ^ c.
;; TEST-EXPECT: compile, run

module AsmTest

define asm-xor3 :: Int -> Int -> Int -> Int
  a b c -> (asm xor a b xor a c)

show (asm-xor3 40 1 3)
