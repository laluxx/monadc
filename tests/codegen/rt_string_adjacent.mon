;; TEST-ID: tests.codegen.rt-string-adjacent
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Adjacent string literals concatenate at compile time.
;; TEST-ATOM: "hello" "world" concatenates to "helloworld".
;; TEST-EXPECT: compile, run

(module Main)
(show "hello""world")
