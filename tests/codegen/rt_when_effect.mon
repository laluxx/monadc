;; TEST-ID: tests.codegen.rt-when-effect
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime when executes its body when the condition is true.
;; TEST-ATOM: (when True (set! x 7)) mutates x.
;; TEST-EXPECT: compile, run

(module Main)
(define x 0)
(when True (set! x 7))
(show x)
