;; TEST-ID: tests.codegen.wisp-comparison
;; TEST-CONTEXT: monadc.context.language.syntax-corpus
;; TEST-PURPOSE: Wisp inline if with >= comparison compiles and evaluates correctly.
;; TEST-ATOM: (if (>= 5 3) 42 0) evaluates to 42.
;; TEST-EXPECT: compile, run

(module Main)
if >= 5 3 then show 42 else show 0
