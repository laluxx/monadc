;; TEST-ID: tests.codegen.rt-set-literal-count
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Runtime set predicates and count observe set literals.
;; TEST-ATOM: Set?, collection?, and count recognize a literal set.
;; TEST-EXPECT: compile, run

(module Main)
(define s {1 2})
(show (Set? s))
(show (collection? s))
(show (count s))
