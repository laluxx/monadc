;; TEST-ID: tests.codegen.rt-layout-field-mutation
;; TEST-CONTEXT: monadc.context.language.runtime-codegen-corpus
;; TEST-PURPOSE: Layout field access and mutation via set! works.
;; TEST-ATOM: (layout Vec2 [x :: Int] [y :: Int]) with field get/set.
;; TEST-EXPECT: compile, run

(module Main)
(layout Vec2 [x :: Int] [y :: Int])
(define v (Vec2 10 20))
(show v.x)
(set! v.x 99)
(show v.x)
