;; TEST-ID: tests.reader.heap-literals
;; TEST-CONTEXT: monadc.context.reader.heap-arrays, monadc.context.language.runtime-sized-arrays, monadc.context.tests.metadata-format
;; TEST-PURPOSE: Verify heap array literals survive parsing and runtime use through show, count, and Wisp for iteration.
;; TEST-ATOM: A top-level heap array define must emit is_heap JSON, print its elements, expose runtime count, and be indexable by for desugaring.
;; TEST-EXPECT: json:array.is_heap, compile, run

(module HeapLiterals)

(define heap ~[1 2 3])
(show heap)
(show (count heap))
for i -> heap
  show i
