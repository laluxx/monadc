;;; Asm

;; 1. Define variables in lisp with define.
;; 2. Use them in asm blocks naturally,
;; 3. Commas omitted to make asm more lispy.
;; 4. Last instruction's value is returned.
;; 5. Multiple returns => List.

;; The major-mode does asm syntax highlighting inside the expression

;; TODO Parametric polymorphism
;; (define (add x y)
;;   (asm add x y))

;; (define (add [x :: Int] -> [y :: Int] -> Int)
;;   (asm add %rdi, %rsi))

;; (define (add [x :: Int] -> [y :: Int] -> Int)
;;   (asm add x y))

(define (rdtsc -> Int)
  (asm rdtsc
       shl 32   %rdx
       or  %rdx %rax))

#+X86-64
(define (get-pid -> Int)
  (asm mov 39 %rax
       syscall))
#---
;; #+ARM32
;; (define (get-pid -> Int)
;;   (asm mov r7 #20; TODO Support # for ARM
;;        swi #0))
;; #---

;; Naked function
(define (addnaked [x :: Int] -> [y :: Int] -> Int)
  :doc "Documentation for this Scheiße."
  :naked True
  (asm
    push %rbp          ; prologue
    mov  %rsp %rbp
    mov  x    %rax     ; x is first  param (in rdi)
    add  y    %rax     ; y is second param (in rsi)
    pop  %rbp          ; epilogue
    ret))              ; return

(define (addnonaked [x :: Int] -> [y :: Int] -> Int)
  :naked False
  (asm add x y))

(show "HERE ASM")
(show "testing naked function")
(show (addnaked 60 70))
(show "testing non naked function")
(show (addnonaked 20 15))

(show (rdtsc))
