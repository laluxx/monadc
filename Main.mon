;;;; TODO Vector

;; One important property of vectors is homogeneity, allows to:
;;  - Store data contiguously in memory (cache-friendly)
;;  - Use SIMD instructions (do 4 operations at once)
;;  - Compile to tight loops without runtime type dispatch
;;  - Call into C without copying/converting
;;
;; Without homogeneity, we lose all of this.
;; You're just writing syntactic sugar over lists.

;; (define v #[1 2 3 4]); NOTE we can infer the type
;; (define [v :: Vec :: Int] #[1 2 3 4])
;; (+ 1 v); => #[2 3 4 5]
;; (* 2 v); => #[2 4 6 8]
;; (* v v); => #[1 4 9 16]

;; Recycling Rules:

;; longer vector length not a multiple of shorter vector
;; (+ #[1 2 3 4] #[10 20]); => #[11 22 13 24]

;; Scalar recycling
;; (+ #[1 2 3 4] 10); => #[11 12 13 14]

;; Boolean Masking:

;; (define v #[10 20 30 40 50])

;; Comparison returns boolean vector
;; (define mask (> v 25)); => #[#f #f #t #t #t]

;; Use mask to select elements
;; (v mask); => #[30 40 50]

;; Compound conditions ?
;; (v (and (> v 20) (< v 40)))  ;; #[30]

;; Indexing and Slicing:

;; (define v #[10 20 30 40 50])

;; Single index
;; (v 0)        ;; 10
;; (v -1)       ;; 50 (negative = from end)

;; Range slices
;; (v (range 1 3))   ; #[20 30 40] (inclusive)             (1:3)
;; (v (range 1 4 2)) ; #[20 40]    (start end step)        (1:4:2)
;; (v (range _ _ 2)) ; #[10 30 50] (every 2nd)             (::2)
;; (v (range 3 _))   ; #[40 50]    (from index 3 to end)   (3:)
;; (v (range_ 2))    ; #[10 20]    (from start to index 2) (:2)

