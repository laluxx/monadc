;;;; Pair

;; (define ordered-pair (1,2)); Inferred as [ordered-pair :: Ordpair]
;; (define [ordered-pair :: Pair :: Ordered] (1,2)); Manually typed

;; NOTE Ordered by itself is not a type, It's more like an enum.

;; The standard Kuratowski definition defines an ordered pair as
;; (a,b) = {{a},{a,b}}, which satisfies the crucial property that
;; (a,b) = (c,d) if and only if a = c and b = d.

;; using pure set theory to distinguish the first element from the second,
;; even if they are identical.

;;;;; Structure:
;; The pair is defined as a set containing two elements:
;; a [[https://en.wikipedia.org/wiki/Singleton_(mathematics)][singleton set]] of the first element {a} and a doubleton set of both elements {a,b}.

;;;;; Order Dependence:
;; If a != b, the first element a is identified by being the only element
;; present in only one of the inner sets, specifically the one that is a singleton, {a}.

;;;;; Purpose:
;; It allows for the construction of [[https://en.wikipedia.org/wiki/Cartesian_product][Cartesian products]] and mathematical
;; relations within formal set theories like [[https://en.wikipedia.org/wiki/Zermelo%E2%80%93Fraenkel_set_theory][Zermelo–Fraenkel set theory]] (ZF).

;;;;; Equality Property:
;; It satisfies
;; (a,b) = (c,d) <=> a = c and b = d, ensuring that
;; (a,b) != (b,a) unless a = b.


;; (define unordered-pair {1,2}); Inferred as [unordered-pair :: Pair :: Unordered]
;; (define [unordered-pair :: Pair :: Unordered] {1,2}); Manually typed


;;;; TODO Relation

;; [y :: Oct] Functions parameters are themselfs relations
;   ^ Here we are saying the symbol =y= is of type Oct

;; (define ages {("Alice"   , 30)
;;               ("Bob"     , 25)
;;               ("Charlie" , 30)}); Inferred as [ages :: Relation]

;; (define [ages :: Relation] {("Alice"   , 30)
;;                             ("Bob"     , 25)
;;                             ("Charlie" , 30)}); Manually typed

;;;;; domain
;; Get all first elements from a relation

;; (domain ages); => {"Alice" "Bob" "Charlie"}

;; Functions are relations too ([[https://en.wikipedia.org/wiki/Morphism][morphisms]]), we can get the domain for them too.
;; (domain multo); => {Oct × Oct} This is a [[https://en.wikipedia.org/wiki/Cartesian_product][certesian product]]

;; We can also get the domain of a type relation. Since they are.. relations.
;; (domain [x :: Int]); -> {x}  (a Singleton containing the x symbol name)

;;;;; codomain
;; Get all second elements from a relation

;; The [[https://en.wikipedia.org/wiki/Codomain][codomain]] of a relation is also called the range of the relation.
;; (codomain ages); => {30 25} NOTICE How 30 appears only once.
;; (codomain multo); => {Oct}  A set containing the output type of the function.
;; (codomain [x :: Int]); => {Int}

;;;;; image
;; For a given element x, return the SET of all elements y
;; that are related to x in the relation.
;; If x is not in the domain, returns the empty set {}.

;; (image ages "Alice")   ; => {30}
;; (image ages "Bob")     ; => {25}
;; (image ages "Charlie") ; => {30}
;; (image ages "David")   ; => {} - Not present in the relation.

;; We can also get the image of functions, since they are relations.

;; For unary functions:
;; (define (double [x :: Int] -> Int) (* x 2))
;; (image double 5); => {10}  (output as a set)

;; For non-unary functions:
;; (image multo 0xFF); => {(lambda ([y :: Oct]) (* 0xFF y))}

;; NOTICE How images of non-unary functions always produce
;; a singleton containing the continuation.

;;;;; preimage

;; preimage: given a y, find ALL x related to it

;; (preimage ages 30)   ; => {"Alice", "Charlie"} - Who is 30?
;; (preimage ages 25)   ; => {"Bob"}              - Who is 25?
;; (preimage ages 40)   ; => {}                   - Nobody is 40

;; (preimage double 6)  ; => {3}
;; (preimage double 30) ; => {15}
;; (preimage double 7)  ; => {} - no integer gives 7 when doubled (3.5 would, but Int only)

;;;;; compose

;; R ∘ S: (a,c) exists if (a,b) in R and (b,c) in S

;; (define life-stages {(30 , "young-adult")
;;                      (25 , "adult")
;;                      (40 , "middle-age")})

;; (ages `∘` life-stages); => {("Alice"   , "young-adult")
;;                     ;     ("Bob"     , "adult")
;;                     ;     ("Charlie" , "young-adult")}

;;;;; transpose
;; Reverse all pairs: (b,a) for each (a,b)




;; union       - All pairs in either relation
;; intersection- Pairs in both relations
;; difference  - Pairs in first but not second

;; select      - Filter pairs by a predicate
;; project     - Keep only specific components

;; restrict    - Keep only pairs with domain in a set
;; corestrict  - Keep only pairs with codomain in a set

;; is-function? - Check if relation is a function (each x maps to unique y)
;; is-injective?- Check if relation is injective (each y has unique x)
;; is-surjective?- Check if relation covers entire codomain



