;;; Loops

;;;; For

;; Without step, default to 1
(for [i 0 10]
  (show "iter n _" i))

;; With step 2
(for [i 0 10 2]
  (show "iter n _" i))

;; Without binding
(for [10]
  (show "looping 10 times!"))


